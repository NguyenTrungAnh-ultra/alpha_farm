{
    "name": "[10m] LinearReg_Slope_BB_Breakout",
    "timeframe": "10m",
    "family": "channel",
    "description": "Uses Linear Regression Slope for trend direction and Bollinger Bands as dynamic channel boundaries. Entry on breakout with slope confirmation, exit when price reverts to regression line or crosses back inside the band.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "slope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=20)"
            },
            {
                "name": "bbands_upper",
                "definition": "self.feat.bbands(high, low, close, timeperiod=14).upper"
            },
            {
                "name": "bbands_lower",
                "definition": "self.feat.bbands(high, low, close, timeperiod=14).lower"
            },
            {
                "name": "regression_line",
                "definition": "self.feat.linearreg(close, timeperiod=20)"
            }
        ],
        "entry_long": "(close > bbands_upper) & (slope > 0.5)",
        "entry_short": "(close < bbands_lower) & (slope < -0.5)",
        "exit_long": "(close <= regression_line) | (close < bbands_upper)",
        "exit_short": "(close >= regression_line) | (close > bbands_lower)"
    },
    "param_space": {
        "timeperiod_slope": {
            "type": "int",
            "low": 10,
            "high": 40,
            "step": 5
        },
        "slope_threshold_long": {
            "type": "float",
            "low": -2.0,
            "high": 3.0,
            "step": 0.5
        },
        "timeperiod_bbands": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 2
        }
    }
}