{
    "name": "[30m] StochRSI_BB_MeanReversion",
    "timeframe": "30m",
    "family": "mean-reversion",
    "description": "Mean reversion strategy using Stochastic RSI and Bollinger Bands to identify price extremes. Enters on touch of lower/upper band with oscillator confirmation, exits when price crosses back towards the middle or signal reverses.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "stochrsi_val",
                "definition": "self.feat.stochrsi(close, timeperiod=14)"
            },
            {
                "name": "bb_upper",
                "definition": "self.feat.bbands(high, low, close, timeperiod=20).upper"
            },
            {
                "name": "bb_middle",
                "definition": "self.feat.bbands(high, low, close, timeperiod=20).middle"
            }
        ],
        "entry_long": "(close < bb_lower) & (stochrsi_val <= 50)",
        "entry_short": "(close > bb_upper) & (stochrsi_val >= 50)",
        "exit_long": "(close >= bb_middle) | (not(entry_long))",
        "exit_short": "(close <= bb_middle) | (not(entry_short))"
    },
    "param_space": {
        "bb_period": {
            "type": "int",
            "low": 10,
            "high": 35,
            "step": 2
        },
        "stochrsi_period": {
            "type": "int",
            "low": 8,
            "high": 24,
            "step": 1
        },
        "long_threshold": {
            "type": "float",
            "low": 0.9,
            "high": 0.95,
            "step": 0.01
        }
    }
}