{
    "name": "NatR_Ema_VolExpansion",
    "timeframe": "60m",
    "family": "volatility",
    "description": "Detects trend direction using EMA and confirms market regime via NATR volatility expansion relative to its rolling mean. Exits on price reversal or significant volatility contraction.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ema_fast",
                "definition": "self.feat.ema(close, timeperiod=param_1)"
            },
            {
                "name": "natr_volatility",
                "definition": "self.feat.natr(high, low, close, timeperiod=20)"
            },
            {
                "name": "mean_natr_regime",
                "definition": "self.op.rolling_mean(natr_volatility, timeperiod=param_2)"
            }
        ],
        "entry_long": "(close > ema_fast) & (natr_volatility > mean_natr_regime)",
        "entry_short": "(close < ema_fast) & (mean_natr_regime >= natr_volatility)",
        "exit_long": "(close <= ema_fast) | (natr_volatility < self.op.rolling_min(natr_volatility, timeperiod=10))",
        "exit_short": "(close >= ema_fast) | (natr_volatility > mean_natr_regime)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 5,
            "high": 30,
            "step": 1
        },
        "vol_lookback": {
            "type": "int",
            "low": 5,
            "high": 40,
            "step": 1
        }
    }
}