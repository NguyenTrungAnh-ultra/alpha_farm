{
    "name": "OBV_Slope_Volatility_Filter",
    "timeframe": "10m",
    "family": "trend-following",
    "description": "Uses On-Balance Volume to confirm buying/selling pressure, linear regression slope of price to gauge trend direction, and Normalized Average True Range to filter low volatility regimes. Enters long when OBV above its SMA, slope positive, and volatility sufficient; exits when either OBV falls below SMA or slope turns negative. Short side is symmetric.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "OBV",
                "definition": "self.feat.obv(close, volume)"
            },
            {
                "name": "OBV_SMA",
                "definition": "self.feat.sma(OBV, timeperiod=20)"
            },
            {
                "name": "LinReg_Slope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=20)"
            },
            {
                "name": "NATR",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(OBV > OBV_SMA) & (LinReg_Slope > 0) & (NATR > 1.0)",
        "entry_short": "(OBV < OBV_SMA) & (LinReg_Slope < 0) & (NATR > 1.0)",
        "exit_long": "(OBV < OBV_SMA) | (LinReg_Slope < 0)",
        "exit_short": "(OBV > OBV_SMA) | (LinReg_Slope > 0)"
    },
    "param_space": {
        "obv_sma_period": {
            "type": "int",
            "low": 10,
            "high": 40,
            "step": 5
        },
        "slope_period": {
            "type": "int",
            "low": 10,
            "high": 40,
            "step": 5
        },
        "natr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 2
        },
        "natr_min": {
            "type": "float",
            "low": 0.5,
            "high": 3.0,
            "step": 0.25
        }
    }
}