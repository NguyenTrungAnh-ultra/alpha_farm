{
    "name": "Micro_DEMA_ADXR_Volume_Scalper",
    "timeframe": "1m",
    "family": "momentum",
    "description": "Ultra-fast scalping strategy using price crossing a fast Double Exponential Moving Average (DEMA), confirmed by rising ADXR (smoothed directional strength) and a volume spike. Exit uses a chandelier-style trailing stop based on ATR. ADX filter prevents trades in low-volatility sideways regimes.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "DEMA_fast",
                "definition": "DEMA(close, timeperiod=DEMA_period)"
            },
            {
                "name": "ADXR",
                "definition": "ADXR(high, low, close, timeperiod=ADXR_period)"
            },
            {
                "name": "ADX",
                "definition": "ADX(high, low, close, timeperiod=ADX_period)"
            },
            {
                "name": "vol_ma",
                "definition": "SMA(volume, timeperiod=vol_ma_period)"
            },
            {
                "name": "ATR",
                "definition": "ATR(high, low, close, timeperiod=ATR_period)"
            },
            {
                "name": "highest_high",
                "definition": "MAX(high, timeperiod=chandelier_lookback)"
            },
            {
                "name": "lowest_low",
                "definition": "MIN(low, timeperiod=chandelier_lookback)"
            }
        ],
        "entry_long": "close > DEMA_fast AND ADXR > ADX_threshold AND ADX > ADX_threshold AND volume > vol_ma * vol_multiplier",
        "entry_short": "close < DEMA_fast AND ADXR > ADX_threshold AND ADX > ADX_threshold AND volume > vol_ma * vol_multiplier",
        "exit_logic": "For long positions: exit when close < (highest_high - ATR * trail_multiplier). For short positions: exit when close > (lowest_low + ATR * trail_multiplier)."
    },
    "param_space": {
        "DEMA_period": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "ADXR_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "ADX_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "ADX_threshold": {
            "type": "int",
            "low": 20,
            "high": 30,
            "step": 1
        },
        "vol_ma_period": {
            "type": "int",
            "low": 5,
            "high": 20,
            "step": 1
        },
        "vol_multiplier": {
            "type": "float",
            "low": 1.2,
            "high": 2.0,
            "step": 0.1
        },
        "ATR_period": {
            "type": "int",
            "low": 7,
            "high": 14,
            "step": 1
        },
        "trail_multiplier": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        },
        "chandelier_lookback": {
            "type": "int",
            "low": 5,
            "high": 20,
            "step": 1
        }
    }
}