{
    "name": "[30m] Stochf_Ema_Pullback_Trend",
    "timeframe": "30m",
    "family": "trend-following",
    "description": "Captures pullbacks in the main trend using EMA direction filtered by Oversold/Overbought Stochastic. Avoids Slope and ADX saturation.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_fast",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "Stochf",
                "definition": "self.feat.stochf(high, low, close, 14)}"
            },
            {
                "name": "SMA_slow",
                "definition": "self.feat.sma(close, timeperiod=50)"
            }
        ],
        "entry_long": "(close > EMA_fast) & (stochf < lower_limit)",
        "entry_short": "(close < SMA_slow) & (stochf > upper_limit)",
        "exit_long": "(close <= EMA_fast)",
        "exit_short": "(close >= SMA_slow)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 10,
            "high": 50,
            "step": 2
        },
        "stochf_k": {
            "type": "float",
            "low": 3.0,
            "high": 9.0,
            "step": 0.5
        }
    }
}