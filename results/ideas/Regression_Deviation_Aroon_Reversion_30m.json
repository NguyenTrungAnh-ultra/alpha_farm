{
    "name": "Regression_Deviation_Aroon_Reversion",
    "timeframe": "30m",
    "family": "mean-reversion",
    "description": "Mean reversion strategy that enters when price deviates significantly from the linear regression line (z-score threshold) while Aroon confirms the trend direction (uptrend for long, downtrend for short). Exits when price reverts to the regression line or when deviation becomes extreme (stop loss). Designed for 0-2 trades per day on VN30F1M.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "linreg",
                "definition": "self.feat.linearreg(close, timeperiod=L)"
            },
            {
                "name": "residual",
                "definition": "close - linreg"
            },
            {
                "name": "stddev_res",
                "definition": "self.feat.stddev(residual, timeperiod=L).clip(lower=1e-8)"
            },
            {
                "name": "zscore",
                "definition": "residual / stddev_res"
            },
            {
                "name": "aroon_up",
                "definition": "self.feat.aroon(high, low, timeperiod=A_period)[1]"
            },
            {
                "name": "aroon_down",
                "definition": "self.feat.aroon(high, low, timeperiod=A_period)[0]"
            },
            {
                "name": "aroon_diff",
                "definition": "aroon_up - aroon_down"
            }
        ],
        "entry_long": "(zscore < -entry_thresh) & (aroon_up > aroon_down) & (aroon_diff > diff_thresh)",
        "entry_short": "(zscore > entry_thresh) & (aroon_down > aroon_up) & (-aroon_diff > diff_thresh)",
        "exit_logic": "Exit Long: (close > linreg) | (zscore < -stop_mult). Exit Short: (close < linreg) | (zscore > stop_mult)."
    },
    "param_space": {
        "L": {
            "type": "int",
            "low": 20,
            "high": 60,
            "step": 5
        },
        "entry_thresh": {
            "type": "float",
            "low": 1.5,
            "high": 2.5,
            "step": 0.1
        },
        "stop_mult": {
            "type": "float",
            "low": 2.5,
            "high": 4.0,
            "step": 0.2
        },
        "A_period": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 5
        },
        "diff_thresh": {
            "type": "int",
            "low": 15,
            "high": 35,
            "step": 5
        }
    }
}