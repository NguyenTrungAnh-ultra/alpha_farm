{
    "name": "Session_Cci_Roc_Breakout",
    "timeframe": "10m",
    "family": "session-based",
    "description": "Intraday momentum breakout strategy using CCI and ROC to confirm trend strength during high volatility sessions, filtered by price position relative to SMA.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "SMA_Trend",
                "definition": "self.feat.sma(close, timeperiod=30)"
            },
            {
                "name": "CCI_Mom",
                "definition": "self.feat.cci(high, low, close)"
            },
            {
                "name": "ROC_Accel",
                "definition": "self.feat.roc(close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > SMA_Trend) & (CCI_Mom > 50)",
        "entry_short": "(close < SMA_Trend) & (CCI_Mom < -50)",
        "exit_long": "(close < SMA_Trend) | (CCI_Mom < 20)",
        "exit_short": "(close > SMA_Trend) | (CCI_Mom > -20)"
    },
    "param_space": {
        "SMA_Period": {
            "type": "int",
            "low": 15,
            "high": 60,
            "step": 5
        },
        "CCI_Threshold": {
            "type": "float",
            "low": 30.0,
            "high": 200.0,
            "step": 10
        }
    }
}