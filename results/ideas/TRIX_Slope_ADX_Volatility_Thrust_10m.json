{
    "name": "TRIX_Slope_ADX_Volatility_Thrust",
    "timeframe": "10m",
    "family": "momentum",
    "description": "Uses TRIX momentum oscillator slope crossing a positive threshold, confirmed by ADX trend strength and Bollinger Band width volatility expansion. Exits on momentum reversal or ATR-based trailing stop.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "TRIX",
                "definition": "self.feat.trix(close, timeperiod=trix_period)"
            },
            {
                "name": "TRIX_slope",
                "definition": "self.feat.linearreg_slope(self.feat.trix(close, timeperiod=trix_period), timeperiod=3)"
            },
            {
                "name": "ADX",
                "definition": "self.feat.adx(high, low, close, timeperiod=adx_period)"
            },
            {
                "name": "BB_width",
                "definition": "(self.feat.bbands(close, timeperiod=bb_period, nbdevup=2, nbdevdn=2)[0] - self.feat.bbands(close, timeperiod=bb_period, nbdevup=2, nbdevdn=2)[2]) / self.feat.bbands(close, timeperiod=bb_period, nbdevup=2, nbdevdn=2)[1]"
            },
            {
                "name": "EMA20",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "max_high_10",
                "definition": "self.feat.max(high, timeperiod=10)"
            },
            {
                "name": "min_low_10",
                "definition": "self.feat.min(low, timeperiod=10)"
            }
        ],
        "entry_long": "(TRIX > 0) & (TRIX_slope > slope_thresh) & (ADX > adx_thresh) & (BB_width > bb_thresh) & (close > EMA20)",
        "entry_short": "(TRIX < 0) & (TRIX_slope < -slope_thresh) & (ADX > adx_thresh) & (BB_width > bb_thresh) & (close < EMA20)",
        "exit_logic": "Exit Long: (TRIX_slope < -exit_slope_thresh) | (close < (max_high_10 - atr_mult * ATR)). Exit Short: (TRIX_slope > exit_slope_thresh) | (close > (min_low_10 + atr_mult * ATR))."
    },
    "param_space": {
        "trix_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 1
        },
        "adx_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "bb_period": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 1
        },
        "slope_thresh": {
            "type": "float",
            "low": 0.001,
            "high": 0.02,
            "step": 0.001
        },
        "exit_slope_thresh": {
            "type": "float",
            "low": 0.002,
            "high": 0.03,
            "step": 0.001
        },
        "atr_mult": {
            "type": "float",
            "low": 1.0,
            "high": 3.0,
            "step": 0.2
        }
    }
}