{
    "name": "Ultimate_Slope_Volatility_Trend",
    "timeframe": "30m",
    "family": "momentum",
    "description": "Uses Ultimate Oscillator (ultosc) for momentum extremes, linear regression slope for trend direction, and NATR for volatility regime. Enters long when ultosc crosses above oversold level, slope is positive, and volatility is sufficient. Enters short when ultosc crosses below overbought level, slope is negative, and volatility is sufficient. Exits when momentum reverts to neutral or slope changes sign.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ULT",
                "definition": "self.feat.ultosc(high, low, close, timeperiod1=self.param_ult_period1, timeperiod2=self.param_ult_period2, timeperiod3=self.param_ult_period3)"
            },
            {
                "name": "SLOPE",
                "definition": "self.feat.linearreg_slope(close, timeperiod=self.param_slope_period)"
            },
            {
                "name": "NATR",
                "definition": "self.feat.natr(high, low, close, timeperiod=self.param_natr_period)"
            }
        ],
        "entry_long": "(self.op.crossed_above(ULT, self.param_ult_oversold)) & (SLOPE > 0) & (NATR > self.param_volatility_threshold)",
        "entry_short": "(self.op.crossed_below(ULT, self.param_ult_overbought)) & (SLOPE < 0) & (NATR > self.param_volatility_threshold)",
        "exit_long": "(ULT < self.param_ult_exit_level) | (SLOPE < 0)",
        "exit_short": "(ULT > self.param_ult_exit_level) | (SLOPE > 0)"
    },
    "param_space": {
        "ult_period1": {
            "type": "int",
            "low": 5,
            "high": 10,
            "step": 1
        },
        "ult_period2": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "ult_period3": {
            "type": "int",
            "low": 25,
            "high": 35,
            "step": 1
        },
        "natr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "slope_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 1
        },
        "volatility_threshold": {
            "type": "float",
            "low": 0.5,
            "high": 2.0,
            "step": 0.1
        },
        "ult_oversold": {
            "type": "int",
            "low": 20,
            "high": 35,
            "step": 1
        },
        "ult_overbought": {
            "type": "int",
            "low": 65,
            "high": 80,
            "step": 1
        },
        "ult_exit_level": {
            "type": "int",
            "low": 40,
            "high": 60,
            "step": 1
        }
    }
}