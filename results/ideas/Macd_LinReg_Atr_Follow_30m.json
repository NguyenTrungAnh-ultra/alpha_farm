{
    "name": "Macd_LinReg_Atr_Follow",
    "timeframe": "30m",
    "family": "trend-following",
    "description": "A trend-following strategy using MACD momentum, Linear Regression Slope for direction confirmation, and ATR for volatility filtering. Entry on MACD cross + positive slope; exit based on price structure breakdown.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "MACD_Hist",
                "definition": "self.feat.macd(close, timeperiod=12)"
            },
            {
                "name": "LinearReg_Slope",
                "definition": "self.feat.linearreg_slope(high, low, close, timeperiod=self.param['linearreg_period'])"
            },
            {
                "name": "ATR_Filter",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(macd_crossed_above_zero & (LinearReg_Slope > self.param['slope_threshold'])) & (ATR_Filter < 2.0)",
        "entry_short": "(macd_crossed_below_zero & (LinearReg_Slope < -self.param['slope_threshold']))",
        "exit_long": "(close <= LinearReg_line) | (macd_crossed_below_zero)",
        "exit_short": "(close >= LinearReg_line) | (macd_crossed_above_zero)"
    },
    "param_space": {
        "linearreg_period": {
            "type": "int",
            "low": 5,
            "high": 40,
            "step": 1
        },
        "slope_threshold": {
            "type": "float",
            "low": -2.0,
            "high": 30.0,
            "step": 1.0
        }
    }
}