{
    "name": "[15m] Vol_NATR_Adx_Ema_Trend",
    "timeframe": "15m",
    "family": "volatility",
    "description": "Trend-following strategy that enters on price direction aligned with volatility expansion (NATR slope) and ADX regime confirmation. Exits when trend reverses or volatility contracts.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ema",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "natr",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > ema) & (feat.natr - shift(feat.natr, 1)) >= 0.5 * natr & adx >= threshold",
        "entry_short": "(close < ema) & (shift(feat.natr, 1) <= feat.natrslope_threshold)",
        "exit_long": "(close <= ema) | (feat.natr - shift(feat.natr, 2)) < 0.5 * natr",
        "exit_short": "(close >= ema) & (shift(natr_slope), -1)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 10,
            "high": 60,
            "step": 5
        },
        "natr_threshold": {
            "type": "float",
            "low": 2.0,
            "high": 8.0,
            "step": 0.5
        }
    }
}