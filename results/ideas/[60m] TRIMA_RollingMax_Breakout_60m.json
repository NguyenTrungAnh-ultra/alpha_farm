{
    "name": "[60m] TRIMA_RollingMax_Breakout",
    "timeframe": "60m",
    "family": "breakout",
    "description": "Trend-following breakout strategy using TRIMA for trend direction and Rolling Max of Highs to define resistance levels. ATR filter ensures volatility expansion before entry.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "Trend_Line",
                "definition": "self.feat.trima(close, timeperiod=21)"
            },
            {
                "name": "Resistance_Level",
                "definition": "self.op.rolling_max(high, timeperiod=20)"
            },
            {
                "name": "Volatility_Measure",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close >= Resistance_Level) & (trima_slope > 0)",
        "entry_short": "(close <= Rolling_Max_Low_20) & (trima_slope < 0)",
        "exit_long": "(close < TRIMA_Line) | (atr_volatility_contraction)",
        "exit_short": "(close > T3_Trend)"
    },
    "param_space": {
        "timeperiod_trima": {
            "type": "int",
            "low": 10,
            "high": 50,
            "step": 2
        },
        "timeperiod_rolling_max": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 2
        }
    }
}