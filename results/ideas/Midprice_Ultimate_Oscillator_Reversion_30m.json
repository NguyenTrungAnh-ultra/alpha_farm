{
    "name": "Midprice_Ultimate_Oscillator_Reversion",
    "timeframe": "30m",
    "family": "mean-reversion",
    "description": "Mean-reversion strategy that enters when price deviates significantly from the midprice (equilibrium) and Ultimate Oscillator reaches extreme levels. Exits when price reverts to midprice or hits a volatility-based stop loss using NATR.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "MIDPRICE",
                "definition": "self.feat.midprice(high, low, timeperiod=midprice_period)"
            },
            {
                "name": "ULTOSC",
                "definition": "self.feat.ultosc(high, low, close, timeperiod1=7, timeperiod2=14, timeperiod3=28)"
            },
            {
                "name": "NATR",
                "definition": "self.feat.natr(high, low, close, timeperiod=natr_period)"
            }
        ],
        "entry_long": "(close < (MIDPRICE - deviation_mult * NATR)) & (ULTOSC < ult_oversold)",
        "entry_short": "(close > (MIDPRICE + deviation_mult * NATR)) & (ULTOSC > ult_overbought)",
        "exit_logic": "Exit Long: (close > MIDPRICE) | (close < (MIDPRICE - stop_mult * NATR)). Exit Short: (close < MIDPRICE) | (close > (MIDPRICE + stop_mult * NATR))."
    },
    "param_space": {
        "midprice_period": {
            "type": "int",
            "low": 20,
            "high": 60,
            "step": 5
        },
        "natr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 2
        },
        "deviation_mult": {
            "type": "float",
            "low": 1.0,
            "high": 3.0,
            "step": 0.2
        },
        "stop_mult": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.2
        },
        "ult_oversold": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 5
        },
        "ult_overbought": {
            "type": "int",
            "low": 70,
            "high": 90,
            "step": 5
        }
    }
}