{
    "name": "[60m] Midpoint_CMFCross_ATR_Trail",
    "timeframe": "60m",
    "family": "channel",
    "description": "Uses the intrabar midpoint (High+Low)/2 as a dynamic channel center, combined with CMF volume flow and ATR volatility filtering to identify mean-reversion bounces or trend continuations within price range.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "Midpoint_Channel",
                "definition": "self.feat.midprice(high, low)"
            },
            {
                "name": "CMF_Flow",
                "definition": "self.feat.cmf(close, volume, timeperiod=10)"
            },
            {
                "name": "ATR_Volatility",
                "definition": "self.feat.atr(high, low, close, timeperiod=20)"
            }
        ],
        "entry_long": "(close > Midpoint_Channel) & (CMF_Flow > 0.5)",
        "entry_short": "(close < Midpoint_Channel) & (CMF_Flow < -0.5)",
        "exit_long": "(close < Midpoint_Channel - ATR_Volatility * 1.2)",
        "exit_short": "(close > Midpoint_Channel + ATR_Volatility * 1.2)"
    },
    "param_space": {
        "CMF_threshold_low": {
            "type": "float",
            "low": -0.5,
            "high": 0.3,
            "step": 0.1
        },
        "CMF_threshold_high": {
            "type": "float",
            "low": 0.2,
            "high": 1.0,
            "step": 0.1
        },
        "ATR_mult_low": {
            "type": "float",
            "low": 0.5,
            "high": 3.0,
            "step": 0.1
        }
    }
}