{
    "name": "[10m] Channel_Break_Ema_Follow",
    "timeframe": "10m",
    "family": "breakout",
    "description": "Breakout strategy using Bollinger Band upper/lower levels with EMA trend confirmation and ATR volatility filter to avoid choppy trades in ranging markets.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ema_fast",
                "definition": "self.feat.ema(close, timeperiod=12)"
            },
            {
                "name": "bb_upper",
                "definition": "self.feat.bbands(high, low, close).upper"
            },
            {
                "name": "bb_lower",
                "definition": "self.feat.bbands(high, low, close).lower"
            }
        ],
        "entry_long": "(close >= bb_upper) & (ema_fast > ema(20))",
        "entry_short": "(close <= bb_lower) & (ema_fast < ema(20))",
        "exit_long": "(close < bb_middle)",
        "exit_short": "(close > bb_middle)"
    },
    "param_space": {
        "ema_period_1": {
            "type": "int",
            "low": 5,
            "high": 30,
            "step": 2
        },
        "ema_slow_period": {
            "type": "int",
            "low": 20,
            "high": 60,
            "step": 5
        }
    }
}