{
    "name": "StochRSI_Divergence_SMA_Fluidity",
    "timeframe": "60m",
    "family": "oscillator-divergence",
    "description": "A mean-reversion to trend-following hybrid strategy using Stochastic RSI momentum divergence against a Simple Moving Average filter, with ATR volatility filtering. Avoids direct volume division by relying on price-based indicators.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "StochRSI",
                "definition": "self.feat.stochrsi(close, timeperiod=14)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=10)"
            }
        ],
        "entry_long": "(close < close_shift(1)) & (stochrsi > 30)",
        "exit_long": "(close >= high_shift(-1)) | (crossed_below_value(stochrsi, value=50)),",
        "entry_short": "(close > close_shift(1)) & (stochrsi < 70) & (~((close >= low_shift(-1))) )",
        "exit_short": "(close <= high_shift(-1)) | (crossed_above_value(stochrsi, value=50)"
    },
    "param_space": {
        "sma_period": {
            "type": "int",
            "low": 20,
            "high": 60,
            "step": 5
        },
        "stochrsi_threshold_low": {
            "type": "float",
            "low": 10.0,
            "high": 40.0,
            "step": 5.0
        },
        "atr_multiplier": {
            "type": "float",
            "low": 0.8,
            "high": 2.0,
            "step": 0.1
        }
    }
}