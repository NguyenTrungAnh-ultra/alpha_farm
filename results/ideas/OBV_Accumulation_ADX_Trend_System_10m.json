{
    "name": "OBV_Accumulation_ADX_Trend_System",
    "timeframe": "10m",
    "family": "trend-following",
    "description": "Uses On-Balance Volume (OBV) to detect accumulation/distribution, confirmed by ADX trend strength. Enters when OBV crosses its EMA and ADX above threshold. Exits with ATR-based trailing stop to lock in profits during strong trends.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "ADX",
                "definition": "ADX(high, low, close, timeperiod=adx_period)"
            },
            {
                "name": "OBV",
                "definition": "OBV(close, volume)"
            },
            {
                "name": "EMA_OBV",
                "definition": "EMA(OBV, timeperiod=obv_ema_period)"
            },
            {
                "name": "ATR",
                "definition": "ATR(high, low, close, timeperiod=14)"
            },
            {
                "name": "HIGHEST_HIGH",
                "definition": "MAX(high, timeperiod=trail_lookback)"
            },
            {
                "name": "LOWEST_LOW",
                "definition": "MIN(low, timeperiod=trail_lookback)"
            }
        ],
        "entry_long": "(OBV > EMA_OBV) and (ADX > adx_threshold)",
        "entry_short": "(OBV < EMA_OBV) and (ADX > adx_threshold)",
        "exit_logic": "Long exit: close < HIGHEST_HIGH - trail_mult * ATR; Short exit: close > LOWEST_LOW + trail_mult * ATR"
    },
    "param_space": {
        "adx_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 1
        },
        "adx_threshold": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 2
        },
        "obv_ema_period": {
            "type": "int",
            "low": 10,
            "high": 40,
            "step": 2
        },
        "trail_lookback": {
            "type": "int",
            "low": 5,
            "high": 20,
            "step": 1
        },
        "trail_mult": {
            "type": "float",
            "low": 1.0,
            "high": 3.0,
            "step": 0.1
        }
    }
}