{
    "name": "[10m] Stochrsi_Cmf_Divergence_Breakout",
    "timeframe": "10m",
    "family": "oscillator-divergence",
    "description": "Captures momentum divergence between price and oscillator (StochRSI) confirmed by volume flow (CMF), filtered by volatility expansion to avoid choppy markets.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "stochrsi_fast",
                "definition": "self.feat.stochrsi(close, timeperiod=10)"
            },
            {
                "name": "cmf_flow",
                "definition": "self.feat.cmf(high, low, close)"
            },
            {
                "name": "natr_volatility",
                "definition": "self.feat.natr(high, low, close, timeperiod=20)"
            }
        ],
        "entry_long": "(close > close_shift(1)) & (stochrsi_fast < stochrsi_fast_shift(1)) & (cmf_flow >= cmf_flow_threshold)",
        "entry_short": "(close < close_shift(1)) & (stochrsi_fast > stochrsi_fast_shift(1)) & (natr_volatility <= natr_volatility_threshold)",
        "exit_long": "(stochrsi_fast > 80) & (close < close_shift(2))",
        "exit_short": "(stochrsi_fast < 20) & (close > close_shift(2))"
    },
    "param_space": {
        "cmf_flow_threshold": {
            "type": "float",
            "low": -1.5,
            "high": 1.5,
            "step": 0.1
        },
        "natr_volatility_threshold": {
            "type": "float",
            "low": 0.3,
            "high": 2.0,
            "step": 0.1
        }
    }
}