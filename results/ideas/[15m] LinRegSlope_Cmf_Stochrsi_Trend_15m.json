{
    "name": "[15m] LinRegSlope_Cmf_Stochrsi_Trend",
    "timeframe": "15m",
    "family": "trend-following",
    "description": "Trend following strategy using Linear Regression Slope for direction, CMF for volume flow confirmation, and Stochastic RSI to filter momentum pullbacks. Exits on trend reversal or overbought conditions.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_fast",
                "definition": "self.feat.ema(close, timeperiod=10)"
            },
            {
                "name": "LinearReg_Slope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=20)"
            },
            {
                "name": "CMF",
                "definition": "self.feat.cmf(high, low, close, volume, timeperiod=50)"
            },
            {
                "name": "StochRSI_Fast",
                "definition": "self.feat.stochrsi(close, timeperiod=14)"
            }
        ],
        "entry_long": "(LinearReg_Slope > 0.2) & (CMF > EMA_fast_of_CMF) & (StochRSI_Fast < 35)",
        "entry_short": "(LinearReg_Slope < -0.2) & (CMF < EMA_fast_of_CMF) & (StochRSI_Fast > 65)",
        "exit_long": "(LinearReg_Slope <= 0) | (StochRSI_Fast >= 80)",
        "exit_short": "(LinearReg_Slope >= 0) | (StochRSI_Fast <= 20)"
    },
    "param_space": {
        "ema_period_fast": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "linearreg_period": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 2
        },
        "cmf_period": {
            "type": "int",
            "low": 20,
            "high": 60,
            "step": 5
        },
        "stochrsi_fast_k": {
            "type": "float",
            "low": 1.0,
            "high": 3.0,
            "step": 0.1
        }
    }
}