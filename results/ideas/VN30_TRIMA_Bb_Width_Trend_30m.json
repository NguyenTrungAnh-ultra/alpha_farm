{
    "name": "VN30_TRIMA_Bb_Width_Trend",
    "timeframe": "30m",
    "family": "trend-following",
    "description": "Trend following strategy using TRIMA for trend direction and Bollinger Band Width (Volatility) as a filter. Avoids division by zero issues found in raw volume volatility calculations.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "TRIMA",
                "definition": "self.feat.trima(close, timeperiod=20)"
            },
            {
                "name": "BB_Width",
                "definition": "(bbands.upper - bbands.lower) / 1.5"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > trima) & (upper_band_width > atr * 0.8)",
        "entry_short": "(close < trima) & (lower_band_width > atr * 0.8)",
        "exit_long": "(close <= trima)",
        "exit_short": "(close >= trima)"
    },
    "param_space": {
        "timeperiod_trima": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 1
        },
        "atr_mult": {
            "type": "float",
            "low": 0.5,
            "high": 2.0,
            "step": 0.1
        }
    }
}