{
    "name": "[30m] MACD_Cmf_Volatility_Signal",
    "timeframe": "30m",
    "family": "momentum",
    "description": "Momentum strategy using MACD histogram for direction and CMF volume confirmation, filtered by NATR volatility expansion to avoid choppy regimes.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "MACD_Hist",
                "definition": "self.feat.macd(close, timeperiod=12).histogram"
            },
            {
                "name": "CMF_Signal",
                "definition": "self.feat.cmf(high, low, close, volume)"
            },
            {
                "name": "NATR_Filt",
                "definition": "self.feat.natr(high, low, close)"
            }
        ],
        "entry_long": "(MACD_Hist > 0.5) & (CMF_Signal_crosses_above_rolling_mean(CMF_Signal, period=14))",
        "entry_short": "(MACD_Hist < -0.5) & (CMF_Signal_crosses_below_rolling_mean(CMF_Signal, period=14))",
        "exit_long": "(MACD_Hist < 0)",
        "exit_short": "(MACD_Hist > 0)"
    },
    "param_space": {
        "macd_fast_period": {
            "type": "int",
            "low": 8,
            "high": 14,
            "step": 2
        },
        "cmf_rolling_mean_period": {
            "type": "int",
            "low": 5,
            "high": 20,
            "step": 1
        }
    }
}