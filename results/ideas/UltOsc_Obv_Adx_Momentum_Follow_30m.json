{
    "name": "UltOsc_Obv_Adx_Momentum_Follow",
    "timeframe": "30m",
    "family": "multi-indicator",
    "description": "Uses Ultimate Oscillator and OBV to confirm momentum direction, filtered by ADX strength. Exits on price deviation beyond EMA-AVR range.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_fast",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "OBV_Trend",
                "definition": "self.feat.obv(high, low, open_price, volume)"
            },
            {
                "name": "ADX_Filter",
                "definition": "self.feat.adx(high, low, close)"
            }
        ],
        "entry_long": "(close >= EMA_fast) & (OBV_Trend.diff() > 0)",
        "entry_short": "(close <= EMA_fast) & (OBV_Trend.diff() < 0)",
        "exit_long": "(close < EMA_fast - self.feat.natr(high, low, close))",
        "exit_short": "(close > EMA_fast + self.feat.natr(high, low, close))"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 1
        },
        "adx_threshold": {
            "type": "float",
            "low": 20.0,
            "high": 40.0,
            "step": 1.0
        }
    }
}