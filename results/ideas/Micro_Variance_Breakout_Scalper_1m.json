{
    "name": "Micro_Variance_Breakout_Scalper",
    "timeframe": "1m",
    "family": "breakout",
    "description": "Captures explosive price moves following a spike in price variance (volatility of returns), confirmed by volume expansion. Enters when price breaks recent high/low while variance exceeds its short-term average, and volume is above average. Exits using ATR trailing stop based on EMA to capture quick scalping profits.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "VAR_close",
                "definition": "VAR(close, timeperiod=5)"
            },
            {
                "name": "VAR_ema",
                "definition": "EMA(VAR_close, timeperiod=5)"
            },
            {
                "name": "volume_sma",
                "definition": "SMA(volume, timeperiod=10)"
            },
            {
                "name": "ATR",
                "definition": "ATR(high, low, close, timeperiod=7)"
            },
            {
                "name": "EMA_trail",
                "definition": "EMA(close, timeperiod=8)"
            },
            {
                "name": "high_roll",
                "definition": "MAX(high, 3)"
            },
            {
                "name": "low_roll",
                "definition": "MIN(low, 3)"
            }
        ],
        "entry_long": "close > high_roll AND VAR_close > VAR_ema * 1.6 AND volume > volume_sma * 1.3",
        "entry_short": "close < low_roll AND VAR_close > VAR_ema * 1.6 AND volume > volume_sma * 1.3",
        "exit_logic": "Long exit: close < EMA_trail - 1.2 * ATR; Short exit: close > EMA_trail + 1.2 * ATR"
    },
    "param_space": {
        "var_mult": {
            "type": "float",
            "low": 1.2,
            "high": 2.5,
            "step": 0.1
        },
        "vol_mult": {
            "type": "float",
            "low": 1.1,
            "high": 2.0,
            "step": 0.1
        },
        "atr_period": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "ema_trail_period": {
            "type": "int",
            "low": 5,
            "high": 20,
            "step": 1
        },
        "var_period": {
            "type": "int",
            "low": 3,
            "high": 10,
            "step": 1
        },
        "var_ema_period": {
            "type": "int",
            "low": 3,
            "high": 10,
            "step": 1
        }
    }
}