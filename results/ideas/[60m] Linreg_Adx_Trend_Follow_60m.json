{
    "name": "[60m] Linreg_Adx_Trend_Follow",
    "timeframe": "60m",
    "family": "trend-following",
    "description": "Trend following strategy using Linear Regression Price position and ADX regime filter. Enters when price is above the trend line with strong volatility, exits on reversal or ATR expansion.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "linreg_price",
                "definition": "self.feat.linearreg(close, timeperiod=20)"
            },
            {
                "name": "adx_regime",
                "definition": "self.feat.adx(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > linreg_price) & (linreg_slope >= 0.5) & (adx_regime >= 20)",
        "entry_short": "(close < linreg_price) & (linreg_slope <= -0.5) & (adx_regime >= 20)",
        "exit_long": "(close < linreg_price) | (atr(high, low, close, timeperiod=14) > self.feat.atr(high, low, close, timeperiod=3).mean())",
        "exit_short": "(close > linreg_price) | (atr(high, low, close, timeperiod=14) < 0.5)"
    },
    "param_space": {
        "linreg_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 2
        },
        "adx_threshold": {
            "type": "float",
            "low": 10,
            "high": 40,
            "step": 5
        }
    }
}