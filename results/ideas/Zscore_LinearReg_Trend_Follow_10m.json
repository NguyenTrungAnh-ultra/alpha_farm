{
    "name": "Zscore_LinearReg_Trend_Follow",
    "timeframe": "10m",
    "family": "trend-following",
    "description": "Trend following strategy using Linear Regression as dynamic support/resistance and Rolling Z-Score for momentum confirmation. Avoids noise by filtering entries when price deviates significantly from mean.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "trend_line",
                "definition": "self.feat.linearreg(close, timeperiod=50)"
            },
            {
                "name": "zscore",
                "definition": "self.feat.rolling_zscore(close, window=30)"
            }
        ],
        "entry_long": "(close >= trend_line) & (zscore > -1)",
        "entry_short": "(close <= trend_line) & (zscore < 1)",
        "exit_long": "(close < trend_line)",
        "exit_short": "(close > trend_line)"
    },
    "param_space": {
        "lr_period": {
            "type": "int",
            "low": 30,
            "high": 60,
            "step": 1
        },
        "zscore_threshold_long": {
            "type": "float",
            "low": -2.5,
            "high": 0,
            "step": 0.1
        }
    }
}