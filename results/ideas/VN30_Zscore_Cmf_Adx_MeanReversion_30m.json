{
    "name": "VN30_Zscore_Cmf_Adx_MeanReversion",
    "timeframe": "30m",
    "family": "mean-revision",
    "description": "Mean Reversion strategy using Rolling Z-Score for overextension detection, confirmed by CMF volume flow and filtered by ADX to ensure range-bound market conditions.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "rolling_zscore",
                "definition": "self.feat.rolling_zscore(close, timeperiod=20)"
            },
            {
                "name": "sma_mean",
                "definition": "self.feat.sma(close, timeperiod=14)"
            },
            {
                "name": "cmf_flow",
                "definition": "self.feat.cmf(high, low, open_price, volume)"
            },
            {
                "name": "adx_strength",
                "definition": "self.feat.adx(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(rolling_zscore < -2.0) & (cmf_flow > 0.5) & (adx_strength < 30)",
        "entry_short": "(rolling_zscore > 2.0) & (cmf_flow < -0.5) & (adx_strength < 30)",
        "exit_long": "(abs(rolling_zscore) < 1.0) | (close >= sma_mean + rolling_std(sma_mean, timeperiod=14))",
        "exit_short": "(abs(rolling_zscore) < 1.0) | (close <= sma_mean - rolling_std(sma_mean, timeperiod=14))"
    },
    "param_space": {
        "zscore_threshold_long": {
            "type": "float",
            "low": -2.5,
            "high": -1.8,
            "step": 0.1
        },
        "adx_filter_limit": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 5
        }
    }
}