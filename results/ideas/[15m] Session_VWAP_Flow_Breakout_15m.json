{
    "name": "[15m] Session_VWAP_Flow_Breakout",
    "timeframe": "15m",
    "family": "session-based",
    "description": "Breaks out from the session's volume-weighted average price (VWAP) when institutional flow aligns. Uses Rolling VWAP as a dynamic pivot and CMF for direction confirmation, avoiding standard EMA/ADX dominance.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "RollingVWAP",
                "definition": "self.feat.rolling_vwap(close)"
            },
            {
                "name": "CMF",
                "definition": "self.feat.cmf(volume, timeperiod=20)"
            },
            {
                "name": "NATR",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > RollingVWAP & CMF > 0.5) | (Natr < threshold)",
        "entry_short": "(close < RollingVWAP & CMF < -0.5) | (Natr < threshold)",
        "exit_long": "(crossed_below(close, RollingVWAP))",
        "exit_short": "(crossed_above(close, RollingVWAP))"
    },
    "param_space": {
        "vwap_period": {
            "type": "int",
            "low": 10,
            "high": 50,
            "step": 2
        },
        "cmf_threshold": {
            "type": "float",
            "low": -0.8,
            "high": 0.8,
            "step": 0.1
        }
    }
}