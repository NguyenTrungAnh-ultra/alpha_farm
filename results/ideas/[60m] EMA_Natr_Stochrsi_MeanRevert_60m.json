{
    "name": "[60m] EMA_Natr_Stochrsi_MeanRevert",
    "timeframe": "60m",
    "family": "mean-reversion",
    "description": "Captures pullbacks to EMA when momentum reverses (StochRSI), filtered by volatility contraction via NATR. Exits on mean re-cross or volatility expansion.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ema_price",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "stochrsi_val",
                "definition": "self.feat.stochrsi(close)"
            },
            {
                "name": "natr_val",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close < ema_price) & (stochrsi_val > stochrsi_threshold_param)",
        "entry_short": "(close > ema_price) & (stochrsi_val < -stochrsi_threshold_param)",
        "exit_long": "(close >= ema_price) | (natr_val > natr_max_param * 2.0)",
        "exit_short": "(close <= ema_price) | (natr_val > natr_max_param * 2.0)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 5,
            "high": 30,
            "step": 1
        },
        "stochrsi_threshold_param": {
            "type": "float",
            "low": -2.0,
            "high": 8.0,
            "step": 0.1
        },
        "natr_max_param": {
            "type": "float",
            "low": 0.5,
            "high": 3.0,
            "step": 0.1
        }
    }
}