{
    "name": "[10m] KAMA_CMF_Vol_Flow_Trend",
    "timeframe": "10m",
    "family": "multi-indicator",
    "description": "Trend-following strategy using Kama as the dynamic trend baseline and CMF to confirm volume flow direction, filtering out low-volume choppy periods.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "KAMA_fast",
                "definition": "self.feat.kama(close, timeperiod=10)"
            },
            {
                "name": "CMF_flow",
                "definition": "self.feat.cmf(timeperiod=20)"
            }
        ],
        "entry_long": "(close > KAMA_fast) & (CMF_flow > 0.5)",
        "entry_short": "(close < KAMA_fast) & (CMF_flow < -0.5)",
        "exit_long": "(close <= KAMA_fast)",
        "exit_short": "(close >= KAMA_fast)"
    },
    "param_space": {
        "kama_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 2
        },
        "cmf_threshold_long": {
            "type": "float",
            "low": -0.5,
            "high": 0.8,
            "step": 0.1
        }
    }
}