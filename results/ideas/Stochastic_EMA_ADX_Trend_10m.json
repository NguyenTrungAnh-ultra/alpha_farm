{
    "name": "Stochastic_EMA_ADX_Trend",
    "timeframe": "10m",
    "family": "trend-following",
    "description": "Uses StochRSI for momentum trigger, EMA direction to confirm trend context, and ADX as a regime filter. Exits on price reversal relative to EMA.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ema_fast",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "stochrsi",
                "definition": "self.feat.stochrsi(high, low, close, fast_k_period=14, slow_d_period=3)"
            },
            {
                "name": "adx_signal",
                "definition": "self.feat.adx(close, high, low, timeperiod=14)"
            }
        ],
        "entry_long": "(crossed_above(stochrsi, 50)) & (close > ema_fast)",
        "entry_short": "(crossed_below(stochrsi, 50)) & (close < ema_fast)",
        "exit_long": "(ema_crosses_below(ema_fast, timeperiod=21) or close < ema_fast)",
        "exit_short": "(ema_crosses_above(ema_fast, timeperiod=21) or close > ema_fast)"
    },
    "param_space": {
        "adx_threshold": {
            "type": "float",
            "low": 15.0,
            "high": 30.0,
            "step": 1
        },
        "stochrsi_k_period": {
            "type": "int",
            "low": 8,
            "high": 24,
            "step": 2
        }
    }
}