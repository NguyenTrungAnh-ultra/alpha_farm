{
    "name": "Slope_Adr_VolatilityBreakout",
    "timeframe": "60m",
    "family": "breakout",
    "description": "Trend breakout strategy using Linear Reg Slope direction confirmation combined with ATR volatility expansion. Avoids MACD/CMF to ensure uniqueness from accepted strategies.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_fast",
                "definition": "self.feat.ema(close, timeperiod=14)"
            },
            {
                "name": "Slope_Trend",
                "definition": "self.feat.linearreg_slope(ema_fast, high, low, close, timeperiod=20)"
            },
            {
                "name": "NATR_Volatility",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > ema_fast) & (Slope_Trend > 0.5)",
        "entry_short": "(close < ema_fast) & (abs(Slope_Trend) > 0.5)",
        "exit_long": "(self.op.crossed_above(ema_fast, close))",
        "exit_short": "(self.op.crossed_below(ema_fast, close))"
    },
    "param_space": {
        "slope_threshold": {
            "type": "float",
            "low": -10.0,
            "high": 20.0,
            "step": 5
        },
        "atr_period": {
            "type": "int",
            "low": 8,
            "high": 30,
            "step": 2
        }
    }
}