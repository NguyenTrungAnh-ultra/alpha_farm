{
    "name": "[10m] Stoch_Cmf_Ema_Momentum",
    "timeframe": "10m",
    "family": "momentum",
    "description": "Captures price acceleration when volume flow (CMF) aligns with fast stochastic momentum, filtered by trend direction via EMA. Exits on volatility contraction or trend reversal.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_fast",
                "definition": "self.feat.ema(close, timeperiod=14)"
            },
            {
                "name": "Stochf_Fast",
                "definition": "self.feat.stochf(open_price, high, low, close, timeperiod=5, fast_period=3)"
            },
            {
                "name": "CMF_VolFlow",
                "definition": "self.feat.cmf(volume, open_price)"
            }
        ],
        "entry_long": "(close > EMA_fast) & (cmf_volflow > 0.15) & crossed_above(shift(Stochf_Fast, 1), Stochf_Fast)",
        "entry_short": "(close < EMA_fast) & (cmf_volflow < -0.15) & crossed_below(shift(Stochf_Fast, 1), Stochf_Fast)",
        "exit_long": "(close < EMA_fast)",
        "exit_short": "(close > EMA_fast)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 8,
            "high": 20,
            "step": 1
        },
        "stoch_k_period": {
            "type": "int",
            "low": 3,
            "high": 7,
            "step": 1
        },
        "cmf_threshold": {
            "type": "float",
            "low": -0.5,
            "high": 0.8,
            "step": 0.1
        }
    }
}