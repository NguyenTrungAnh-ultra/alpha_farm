{
    "name": "T3_LinearReg_Vol_Trail",
    "timeframe": "15m",
    "family": "trend-following",
    "description": "A trend-following strategy using Triple Exponential Moving Average (T3) and Linear Regression Slope to confirm acceleration, filtered by ATR volatility expansion. Avoids ADX/Squeeze/Angle logic found in previous strategies.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "T3_Trend",
                "definition": "self.feat.tema(close, timeperiod=20)"
            },
            {
                "name": "Linear_Reg_Slope",
                "definition": "self.feat.linearreg_slope(open_price, close, timeperiod=14)"
            },
            {
                "name": "ATR_Filter",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > T3_Trend) & (Linear_Reg_Slope > 0.5) & (ATR_Filter > 2.0)",
        "entry_short": "(close < T3_Trend) & (Linear_Reg_Slope < -0.5) & (ATR_Filter > 2.0)",
        "exit_long": "(close <= T3_Trend) | ((T3_Trend + ATR_Filter * 1.5) >= close)",
        "exit_short": "(close >= T3_Trend) | ((T3_Trend - ATR_Filter * 1.5) <= close)"
    },
    "param_space": {
        "ema_period_fast": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 1
        },
        "slope_threshold": {
            "type": "float",
            "low": -3.0,
            "high": 5.0,
            "step": 0.5
        }
    }
}