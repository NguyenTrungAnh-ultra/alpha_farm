{
    "name": "[15m] EMA_Atr_Piercing_Trend",
    "timeframe": "15m",
    "family": "trend-following",
    "description": "Trend following strategy using EMA for direction, ATR for volatility filtering, and Piercing Pattern as confirmation. Avoids Slope/CMF heavy combos to reduce multicollinearity.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_fast",
                "definition": "self.feat.ema(close, timeperiod=14)"
            },
            {
                "name": "ATR_filter",
                "definition": "self.feat.atr(high, low, close, timeperiod=20)"
            }
        ],
        "entry_long": "(close > ema_fast) & (atr_filter < rolling_mean(atr_filter)) & self.op.isna(piercing_pattern())",
        "entry_short": "(close < ema_fast) & (atr_filter < rolling_mean(atr_filter)) & ~self.op.isna(self.feat.piercing_pattern(open_price, close))",
        "exit_long": "(ema_fast > open_price)",
        "exit_short": "(ema_fast < open_price)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 8,
            "high": 20,
            "step": 1
        },
        "atr_period": {
            "type": "float",
            "low": 14.0,
            "high": 35.0,
            "step": 1
        }
    }
}