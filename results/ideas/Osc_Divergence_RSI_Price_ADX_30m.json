{
    "name": "Osc_Divergence_RSI_Price_ADX",
    "timeframe": "30m",
    "family": "oscillator-divergence",
    "description": "Strategy detects Bullish/Bearish divergence between Price and RSI momentum, filtered by ADX trend regime. Uses price structure (High/Low) vs Oscillator peaks to identify reversal points in trending markets.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "RSI_fast",
                "definition": "self.feat.rsi(close, timeperiod=14)"
            },
            {
                "name": "EMA_Trend",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "ADX_Regime",
                "definition": "self.feat.adx(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close >= shift(close)) & (rsi_fast <= shift(rsi_fast)) & (adx_regime > 20)",
        "entry_short": "(close < shift(close)) & (rsi_fast >= shift(rsi_fast)) & (adx_regime > 20)",
        "exit_long": "(close < ema_trend) | (rsi_fast <= shift(rsi_fast))",
        "exit_short": "(close > ema_trend) | (rsi_fast >= shift(rsi_fast))"
    },
    "param_space": {
        "adx_threshold": {
            "type": "int",
            "low": 10,
            "high": 45,
            "step": 2
        },
        "rsi_period": {
            "type": "int",
            "low": 9,
            "high": 25,
            "step": 1
        }
    }
}