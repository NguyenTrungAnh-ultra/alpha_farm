{
    "name": "[15m] EMA_ATR_Channel_Breakout",
    "timeframe": "15m",
    "family": "channel",
    "description": "Trend-following strategy using a dynamic channel defined by EMA +/- ATR volatility expansion. Entry on breakout above upper band with momentum confirmation, exit when price reverts below lower band or trend fails.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "ema_upper",
                "definition": "(self.feat.ema(close) + k * self.feat.atr(high, low, close))"
            },
            {
                "name": "ema_lower",
                "definition": "(self.feat.ema(close) - k * self.feat.atr(high, low, close))"
            }
        ],
        "entry_long": "(close > ema_upper) & (roc(close) > 0)",
        "entry_short": "(close < ema_lower) & (roc(close) < 0)",
        "exit_long": "(close <= ema_lower) | (ema_crosses_below_close)",
        "exit_short": "(close >= ema_upper) | (ema_crosses_above_close)"
    },
    "param_space": {
        "k_atr_mult": {
            "type": "float",
            "low": 0.5,
            "high": 2.0,
            "step": 0.1
        },
        "ema_period": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 1
        }
    }
}