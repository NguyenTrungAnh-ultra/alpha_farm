{
    "name": "Trend_Slope_ATR_Follow",
    "timeframe": "15m",
    "family": "trend-following",
    "description": "A trend-following strategy using Linear Regression Slope for direction and ATR to filter high volatility regimes. It avoids ADX/ROC/MACD logic found in accepted strategies, focusing on slope expansion.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "Slope_20",
                "definition": "self.feat.linearreg_slope(close, timeperiod=20)"
            },
            {
                "name": "EMA_50",
                "definition": "self.feat.ema(close, timeperiod=50)"
            },
            {
                "name": "ATR_14",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(slope > 2.0) & (close >= ema)",
        "entry_short": "(slope < -2.0) & (close <= ema)",
        "exit_long": "(close < ema) | (slope <= 0)",
        "exit_short": "(close > ema) | (slope >= 0)"
    },
    "param_space": {
        "Slope_Period": {
            "type": "int",
            "low": 14,
            "high": 35,
            "step": 2
        },
        "EMA_Period": {
            "type": "int",
            "low": 30,
            "high": 60,
            "step": 5
        },
        "ATR_Multiplier": {
            "type": "float",
            "low": 1.0,
            "high": 3.0,
            "step": 0.2
        }
    }
}