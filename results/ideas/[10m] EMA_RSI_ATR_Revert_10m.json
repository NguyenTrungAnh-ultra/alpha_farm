{
    "name": "[10m] EMA_RSI_ATR_Revert",
    "timeframe": "10m",
    "family": "mean-reversion",
    "description": "Captures mean reversion opportunities when price deviates below the moving average in low volatility regimes, confirmed by RSI oversold conditions. Exits on ATR contraction and price return to EMA.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_20",
                "definition": "self.feat.ema(close, timeperiod=ema_period)"
            },
            {
                "name": "RSI_14",
                "definition": "self.feat.rsi(high, low, close, timeperiod=rsi_level)"
            },
            {
                "name": "ATR_14",
                "definition": "self.feat.atr(high, low, close, timeperiod=atr_period)"
            }
        ],
        "entry_long": "(close < EMA_20) & (RSI_14 <= rsi_threshold)",
        "entry_short": "(close > EMA_20) & (RSI_14 >= 65)",
        "exit_long": "(ATR_14 < atr_target) & (close >= EMA_20)",
        "exit_short": "(ATR_14 < atr_target) & (close <= EMA_20)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 5,
            "high": 30,
            "step": 1
        },
        "rsi_threshold": {
            "type": "float",
            "low": 40.0,
            "high": 70.0,
            "step": 2.0
        }
    }
}