{
    "name": "TEMA_BBPct_ADX_Trail",
    "timeframe": "10m",
    "family": "trend-following",
    "description": "Uses TEMA slope for trend direction, Bollinger Band %B for oversold/overbought pullback entries, and ADX to filter ranging markets. Exits with ATR-based trailing stop or TEMA reversal.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "TEMA",
                "definition": "TEMA(close, timeperiod=tema_period)"
            },
            {
                "name": "TEMA_prev",
                "definition": "shift(TEMA, 1)"
            },
            {
                "name": "upperBB",
                "definition": "BBANDS(close, timeperiod=bb_period, nbdevup=bb_std, nbdevdn=bb_std, matype=0).upperband"
            },
            {
                "name": "lowerBB",
                "definition": "BBANDS(close, timeperiod=bb_period, nbdevup=bb_std, nbdevdn=bb_std, matype=0).lowerband"
            },
            {
                "name": "percentB",
                "definition": "(close - lowerBB) / (upperBB - lowerBB + 1e-8)"
            },
            {
                "name": "ADX",
                "definition": "ADX(high, low, close, timeperiod=adx_period)"
            },
            {
                "name": "ATR",
                "definition": "ATR(high, low, close, timeperiod=atr_period)"
            },
            {
                "name": "trail_max_high",
                "definition": "rolling_max(high, trail_lookback)"
            },
            {
                "name": "trail_min_low",
                "definition": "rolling_min(low, trail_lookback)"
            }
        ],
        "entry_long": "(TEMA > TEMA_prev) AND (percentB < oversold_thresh) AND (ADX > adx_min)",
        "entry_short": "(TEMA < TEMA_prev) AND (percentB > overbought_thresh) AND (ADX > adx_min)",
        "exit_logic": "exit_long when (close < trail_max_high - trail_multiplier * ATR) OR (TEMA < TEMA_prev); exit_short when (close > trail_min_low + trail_multiplier * ATR) OR (TEMA > TEMA_prev)"
    },
    "param_space": {
        "tema_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 2
        },
        "bb_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 2
        },
        "bb_std": {
            "type": "float",
            "low": 1.5,
            "high": 2.5,
            "step": 0.1
        },
        "adx_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "trail_lookback": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "trail_multiplier": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        },
        "oversold_thresh": {
            "type": "float",
            "low": 0.15,
            "high": 0.25,
            "step": 0.01
        },
        "overbought_thresh": {
            "type": "float",
            "low": 0.75,
            "high": 0.85,
            "step": 0.01
        },
        "adx_min": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 1
        }
    }
}