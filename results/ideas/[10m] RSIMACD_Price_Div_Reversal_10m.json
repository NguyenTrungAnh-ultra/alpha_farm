{
    "name": "[10m] RSIMACD_Price_Div_Reversal",
    "timeframe": "10m",
    "family": "oscillator-divergence",
    "description": "Captures momentum divergence between Price Trend (EMA) and Oscillators (RSI/MACD). Enters Long when price is in an uptrend but RSI indicates oversold conditions, suggesting a potential reversal or continuation of trend strength despite low momentum.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_Trend",
                "definition": "self.feat.ema(close, timeperiod=ema_period)"
            },
            {
                "name": "RSI_Oscillator",
                "definition": "self.feat.rsi(high, low, close, timeperiod=rsi_period)"
            },
            {
                "name": "MACD_Hist",
                "definition": "self.feat.macd(close)"
            }
        ],
        "entry_long": "(close > ema_trend) & (rsi_oscillator < 35.0)",
        "entry_short": "(close < ema_trend) & (rsi_oscillator > 65.0)",
        "exit_long": "(close < ema_trend) | (rsi_oscillator >= 45.0)",
        "exit_short": "(close > ema_trend) | (rsi_oscillator <= 35.0)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 12,
            "high": 24,
            "step": 2
        },
        "rsi_period": {
            "type": "int",
            "low": 9,
            "high": 18,
            "step": 3
        }
    }
}