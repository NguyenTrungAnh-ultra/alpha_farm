{
    "name": "RSI_Price_Divergence_NATR_Filter",
    "timeframe": "10m",
    "family": "oscillator-divergence",
    "description": "Captures potential trend exhaustion or reversal by entering when RSI momentum improves (rising) while price remains below the EMA, signaling divergence between technical indicators. Exits on trend reversion.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ema_20",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "rsi_14",
                "definition": "self.feat.rsi(high, low, close, timeperiod=14)"
            },
            {
                "name": "natr_14",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close < ema_20) & (rsi_14 > rsi_14[shift(5)])",
        "entry_short": "(close > ema_20) & (rsi_14 < rsi_14[shift(5)])",
        "exit_long": "(close >= ema_20)",
        "exit_short": "(close <= ema_20)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 10,
            "high": 45,
            "step": 1
        },
        "rsi_threshold_diff": {
            "type": "float",
            "low": -0.2,
            "high": 0.3,
            "step": 0.05
        }
    }
}