{
    "name": "[15m] Bollinger_Ad_X_Volatility_Breakout",
    "timeframe": "15m",
    "family": "volatility",
    "description": "A volatility-filtered breakout strategy using Bollinger Bands for dynamic support/resistance and ADX to confirm trend strength, avoiding choppy sideways markets.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "bb_upper",
                "definition": "self.feat.bbands(high, low, close).upper"
            },
            {
                "name": "bb_lower",
                "definition": "self.feat.bbands(high, low, close).lower"
            },
            {
                "name": "bb_middle",
                "definition": "self.feat.bbands(high, low, close).middle"
            },
            {
                "name": "adx_strength",
                "definition": "self.feat.adx()"
            }
        ],
        "entry_long": "(close > bb_upper) & (adx_strength > adx_threshold)",
        "entry_short": "(close < bb_lower) & (adx_strength > adx_threshold)",
        "exit_long": "(close <= bb_middle) | (close >= high[1])",
        "exit_short": "(close >= bb_middle) | (close <= low[1])"
    },
    "param_space": {
        "adx_threshold": {
            "type": "int|float",
            "low": 2,
            "high": 40,
            "step": 1
        }
    }
}