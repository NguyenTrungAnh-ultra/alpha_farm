{
    "name": "Star_Reversal_ADX_Trail",
    "timeframe": "10m",
    "family": "pattern-based",
    "description": "Uses Morning Star and Evening Star candlestick patterns as primary reversal signals, filtered by ADX trend strength and EMA trend direction. Exits with ATR-based trailing stop from recent extremes.",
    "formula": {
        "inputs": [
            "open",
            "high",
            "low",
            "close",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA",
                "definition": "EMA(close, timeperiod=ema_period)"
            },
            {
                "name": "ADX",
                "definition": "ADX(high, low, close, timeperiod=adx_period)"
            },
            {
                "name": "ATR",
                "definition": "ATR(high, low, close, timeperiod=atr_period)"
            },
            {
                "name": "MORNING_STAR",
                "definition": "CDL_MORNINGSTAR(open, high, low, close)"
            },
            {
                "name": "EVENING_STAR",
                "definition": "CDL_EVENINGSTAR(open, high, low, close)"
            },
            {
                "name": "HIGHEST_HIGH",
                "definition": "MAX(high, trailing_period)"
            },
            {
                "name": "LOWEST_LOW",
                "definition": "MIN(low, trailing_period)"
            }
        ],
        "entry_long": "(MORNING_STAR == 100) AND (close > EMA) AND (ADX > adx_threshold)",
        "entry_short": "(EVENING_STAR == -100) AND (close < EMA) AND (ADX > adx_threshold)",
        "exit_logic": "Exit long when close < (HIGHEST_HIGH - ATR * trailing_mult); Exit short when close > (LOWEST_LOW + ATR * trailing_mult)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 2
        },
        "adx_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "adx_threshold": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 1
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "trailing_period": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "trailing_mult": {
            "type": "float",
            "low": 1.5,
            "high": 4.0,
            "step": 0.5
        }
    }
}