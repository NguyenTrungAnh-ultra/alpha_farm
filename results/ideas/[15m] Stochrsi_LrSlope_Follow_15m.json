{
    "name": "[15m] Stochrsi_LrSlope_Follow",
    "timeframe": "15m",
    "family": "oscillator-divergence",
    "description": "A trend-following strategy using Linear Regression Slope for direction and Stochastic RSI for momentum confirmation. It avoids ADX/CMF reliance found in previous strategies by focusing on price vs regression line dynamics.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "LR_Slope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=20)"
            },
            {
                "name": "StochRSI",
                "definition": "self.feat.stochrsi(close, length14, k3, d3)"
            }
        ],
        "entry_long": "(linearreg_slope > 0.5) & (stochrsi_crossed_above(self.op.shift(stochrsi, timeperiod=2)))",
        "entry_short": "(linearreg_slope < -0.5) & (stochrsi_crossed_below(self.op.shift(stochrsi, timeperiod=2)))",
        "exit_long": "(close < linearreg(close)) | (linearreg_slope <= 0)",
        "exit_short": "(close > linearreg(close)) | (linearreg_slope >= 0)"
    },
    "param_space": {
        "slope_threshold": {
            "type": "float",
            "low": -2.0,
            "high": 5.0,
            "step": 1
        },
        "stoch_length": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 2
        }
    }
}