{
    "name": "WMA_ATR_Angle_Breakout",
    "timeframe": "15m",
    "family": "breakout",
    "description": "15-minute breakout strategy using Weighted Moving Average (WMA) of typical price as adaptive center, ATR-based volatility channel, and linear regression angle of volume-weighted price as confirmation filter to avoid false breakouts during low momentum.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "typical_price",
                "definition": "(high + low + close) / 3"
            },
            {
                "name": "WMA_tp",
                "definition": "WMA(typical_price, timeperiod=WMA_length)"
            },
            {
                "name": "ATR",
                "definition": "ATR(high, low, close, timeperiod=ATR_length)"
            },
            {
                "name": "upper_band",
                "definition": "WMA_tp + channel_mult * ATR"
            },
            {
                "name": "lower_band",
                "definition": "WMA_tp - channel_mult * ATR"
            },
            {
                "name": "volume_weighted_price",
                "definition": "close * volume"
            },
            {
                "name": "price_angle",
                "definition": "linearreg_angle(volume_weighted_price, timeperiod=angle_period)"
            }
        ],
        "entry_long": "close > upper_band AND price_angle > angle_threshold",
        "entry_short": "close < lower_band AND price_angle < -angle_threshold",
        "exit_logic": "For long positions: exit when close < WMA_tp - trail_mult * ATR; For short positions: exit when close > WMA_tp + trail_mult * ATR"
    },
    "param_space": {
        "WMA_length": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 2
        },
        "ATR_length": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "channel_mult": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        },
        "angle_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 2
        },
        "angle_threshold": {
            "type": "float",
            "low": 0.0,
            "high": 1.0,
            "step": 0.1
        },
        "trail_mult": {
            "type": "float",
            "low": 0.8,
            "high": 2.0,
            "step": 0.1
        }
    }
}