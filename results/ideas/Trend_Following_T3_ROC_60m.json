{
    "name": "Trend_Following_T3_ROC",
    "timeframe": "60m",
    "family": "trend-following",
    "description": "Uses T3 as a dynamic trend filter and ROC for momentum confirmation to identify breakouts. Exits when price closes below the EMA or volatility compresses, avoiding hard stop loss levels.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "T3_Trend",
                "definition": "self.feat.t3(close, timeperiod=14)"
            },
            {
                "name": "ROC_Mom",
                "definition": "self.feat.roc(close, timeperiod=5)"
            }
        ],
        "entry_long": "(close > T3_Trend) & (ROC_Mom > 0)",
        "entry_short": "(close < T3_Trend) & (ROC_Mom < 0)",
        "exit_long": "(close < EMA(close, timeperiod=14))",
        "exit_short": "(close > EMA(close, timeperiod=14))"
    },
    "param_space": {
        "T3_Period": {
            "type": "int",
            "low": 5,
            "high": 20,
            "step": 1
        },
        "ROC_Period": {
            "type": "int",
            "low": 3,
            "high": 8,
            "step": 1
        }
    }
}