{
    "name": "RollingZscore_LinearSlope_Trend_Follow",
    "timeframe": "30m",
    "family": "trend-following",
    "description": "A trend-following strategy that uses Linear Regression Slope to identify the market regime (uptrend/downtrend) and Rolling Z-Score to confirm pullback entries within the established trend. It avoids choppy sideways markets by requiring a significant slope direction.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "LinearRegSlope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=20)"
            },
            {
                "name": "RollingZScore",
                "definition": "self.feat.rolling_zscore(close, rolling_mean=True)"
            }
        ],
        "entry_long": "(linearreg_slope > 0) & (rolling_zscore < -1)",
        "entry_short": "(linearreg_slope < 0) & (rolling_zscore > +1)",
        "exit_long": "~(linearreg_slope >= 0) | rolling_zscore > +2",
        "exit_short": "(linearreg_slope >= 0) | rolling_zscore < -2"
    },
    "param_space": {
        "slope_threshold": {
            "type": "float",
            "low": -1.5,
            "high": 1.5,
            "step": 0.1
        },
        "zscore_pullback": {
            "type": "int",
            "low": -2,
            "high": 3,
            "step": 1
        }
    }
}