{
    "name": "[30m] Stochf_Slope_Divergence_Trail",
    "timeframe": "30m",
    "family": "oscillator-divergence",
    "description": "Captures trend continuation pullbacks by aligning Price Slope direction with Oscillator Momentum crossing, avoiding ADX/ROC combinations used in other strategies.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "trend_slope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=20)"
            },
            {
                "name": "stochf_val",
                "definition": "self.feat.stochf(high, low, close, timeperiod=5)"
            },
            {
                "name": "osc_trend",
                "definition": "self.feat.ema(stochf_val, timeperiod=14)"
            }
        ],
        "entry_long": "(linearreg_slope(close) > 0) & (stochf_val.shift(-1) < osc_trend.shift(-1)) & (stochf_val > osc_trend)",
        "entry_short": "(linearreg_slope(close) < 0) & (stochf_val.shift(-1) > osc_trend.shift(-1)) & (stochf_val < osc_trend)",
        "exit_long": "(stochf_val.shift(1) <= osc_trend.shift(1))",
        "exit_short": "(stochf_val.shift(1) >= osc_trend.shift(1))"
    },
    "param_space": {
        "trend_period": {
            "type": "int",
            "low": 5,
            "high": 40,
            "step": 2
        },
        "osc_fast": {
            "type": "int",
            "low": 3,
            "high": 10,
            "step": 1
        },
        "osc_slow": {
            "type": "int",
            "low": 8,
            "high": 25,
            "step": 2
        }
    }
}