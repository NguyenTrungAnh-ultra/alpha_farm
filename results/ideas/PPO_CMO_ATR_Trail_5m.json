{
    "name": "PPO_CMO_ATR_Trail",
    "timeframe": "5m",
    "family": "momentum",
    "description": "Combines Percentage Price Oscillator (PPO) zero-line cross as primary momentum signal with Chande Momentum Oscillator (CMO) to confirm strength, and uses ATR-based trailing stop for exits. Designed for 5-minute VN30F1M futures, capturing directional moves while filtering low-momentum regimes.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "PPO",
                "definition": "self.feat.ppo(close, fastperiod=12, slowperiod=26, matype=0)"
            },
            {
                "name": "CMO",
                "definition": "self.feat.cmo(close, timeperiod=14)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "highest_high",
                "definition": "self.feat.max(high, timeperiod=20)"
            },
            {
                "name": "lowest_low",
                "definition": "self.feat.min(low, timeperiod=20)"
            }
        ],
        "entry_long": "(PPO > 0) & (CMO > 30)",
        "entry_short": "(PPO < 0) & (CMO < -30)",
        "exit_logic": "Exit Long: (close < (highest_high - 2.0 * ATR)). Exit Short: (close > (lowest_low + 2.0 * ATR))."
    },
    "param_space": {
        "ppo_fast": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "ppo_slow": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 2
        },
        "cmo_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "cmo_threshold": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 5
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "atr_multiplier": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        },
        "trail_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 5
        }
    }
}