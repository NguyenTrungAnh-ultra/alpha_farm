{
    "name": "Open_Close_Volatility_Trend",
    "timeframe": "15m",
    "family": "session-based",
    "description": "Session-based trend-following strategy using Open Price as session anchor, ADX for regime filtering, and ATR-adjusted EMA trailing stops to avoid chop.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ema_fast",
                "definition": "self.feat.ema(close, timeperiod=14)"
            },
            {
                "name": "adx_regime",
                "definition": "self.feat.adx(high, low, close, timeperiod=25) > 20"
            },
            {
                "name": "cmf_signal",
                "definition": "self.feat.cmf(open_price, high, low, volume, timeperiod=9)"
            },
            {
                "name": "atr_volatility",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > open_price) & (ema_fast > open_price) & adx_regime & cmf_signal >= 0.5",
        "entry_short": "(close < open_price) & (ema_fast < open_price) & adx_regime & cmf_signal <= -0.5",
        "exit_long": "(close < ema_fast) | (close < (ema_fast - atr_volatility))",
        "exit_short": "(close > ema_fast) | (close > (ema_fast + atr_volatility))"
    },
    "param_space": {
        "adx_threshold": {
            "type": "int",
            "low": 10,
            "high": 50,
            "step": 2
        },
        "cmf_multiplier": {
            "type": "float",
            "low": -1.0,
            "high": 1.0,
            "step": 0.1
        }
    }
}