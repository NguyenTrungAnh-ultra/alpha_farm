{
    "name": "Micro_SAR_Volume_Burst_Scalper",
    "timeframe": "1m",
    "family": "trend-following",
    "description": "1-minute scalping strategy using Parabolic SAR trend flips as primary entry signal, confirmed by volume rate of change burst and ATR expansion. Exits using Donchian channel trailing stop (lowest low for long, highest high for short). Designed for VN30F1M futures with tight stops and frequent trades.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "SAR",
                "definition": "SAR(high, low, acceleration=param_accel, maximum=param_max)"
            },
            {
                "name": "ATR",
                "definition": "ATR(high, low, close, timeperiod=param_atr_period)"
            },
            {
                "name": "Volume_ROC",
                "definition": "ROC(volume + 1e-8, timeperiod=param_vol_roc_period)"
            },
            {
                "name": "Lowest_Low",
                "definition": "low.rolling(window=param_exit_period).min()"
            },
            {
                "name": "Highest_High",
                "definition": "high.rolling(window=param_exit_period).max()"
            }
        ],
        "entry_long": "(close.shift(1) < SAR.shift(1)) and (close > SAR) and (Volume_ROC > param_vol_roc_threshold) and (ATR > ATR.shift(1) * param_atr_expansion_factor)",
        "entry_short": "(close.shift(1) > SAR.shift(1)) and (close < SAR) and (Volume_ROC > param_vol_roc_threshold) and (ATR > ATR.shift(1) * param_atr_expansion_factor)",
        "exit_logic": "For long positions: exit when low < Lowest_Low. For short positions: exit when high > Highest_High."
    },
    "param_space": {
        "param_accel": {
            "type": "float",
            "low": 0.01,
            "high": 0.05,
            "step": 0.01
        },
        "param_max": {
            "type": "float",
            "low": 0.1,
            "high": 0.3,
            "step": 0.05
        },
        "param_atr_period": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "param_vol_roc_period": {
            "type": "int",
            "low": 3,
            "high": 12,
            "step": 1
        },
        "param_vol_roc_threshold": {
            "type": "float",
            "low": 0.2,
            "high": 2.0,
            "step": 0.2
        },
        "param_atr_expansion_factor": {
            "type": "float",
            "low": 1.05,
            "high": 1.5,
            "step": 0.05
        },
        "param_exit_period": {
            "type": "int",
            "low": 3,
            "high": 10,
            "step": 1
        }
    }
}