{
    "name": "Aroon_CMO_ADX_EMA_Trend",
    "timeframe": "15m",
    "family": "multi-indicator",
    "description": "Uses Aroon oscillator for trend direction, ADX for trend strength, CMO for momentum confirmation, and EMA as a trend filter. Enters on strong, confirmed trends and exits on early reversal or momentum loss.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "aroon_osc",
                "definition": "self.feat.aroonosc(high, low, timeperiod=14)"
            },
            {
                "name": "adx",
                "definition": "self.feat.adx(high, low, close, timeperiod=14)"
            },
            {
                "name": "cmo",
                "definition": "self.feat.cmo(close, timeperiod=14)"
            },
            {
                "name": "ema",
                "definition": "self.feat.ema(close, timeperiod=20)"
            }
        ],
        "entry_long": "(aroon_osc > 0) & (adx > 25) & (cmo > 20) & (close > ema)",
        "entry_short": "(aroon_osc < 0) & (adx > 25) & (cmo < -20) & (close < ema)",
        "exit_long": "(aroon_osc < 0) | (cmo < 0) | (close < ema)",
        "exit_short": "(aroon_osc > 0) | (cmo > 0) | (close > ema)"
    },
    "param_space": {
        "aroon_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 1
        },
        "adx_period": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 1
        },
        "cmo_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 1
        },
        "ema_period": {
            "type": "int",
            "low": 10,
            "high": 50,
            "step": 1
        },
        "adx_threshold": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 1
        },
        "cmo_threshold": {
            "type": "int",
            "low": 0,
            "high": 30,
            "step": 1
        }
    }
}