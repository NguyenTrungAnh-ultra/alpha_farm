{
    "name": "Midpoint_Cross_ADX_Trail",
    "timeframe": "30m",
    "family": "trend-following",
    "description": "Trend-following strategy using exponential moving average crossover of midpoint price (high+low)/2. ADX filters out sideways markets. Exit uses ATR-based dynamic trailing stop anchored to the slow midpoint EMA.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "midpoint",
                "definition": "(high + low) / 2"
            },
            {
                "name": "EMA_fast_mid",
                "definition": "self.feat.ema(midpoint, timeperiod=fast_period)"
            },
            {
                "name": "EMA_slow_mid",
                "definition": "self.feat.ema(midpoint, timeperiod=slow_period)"
            },
            {
                "name": "ADX",
                "definition": "self.feat.adx(high, low, close, timeperiod=adx_period)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=atr_period)"
            }
        ],
        "entry_long": "(EMA_fast_mid > EMA_slow_mid) & (ADX > adx_threshold)",
        "entry_short": "(EMA_fast_mid < EMA_slow_mid) & (ADX > adx_threshold)",
        "exit_logic": "Exit Long: close < (EMA_slow_mid - exit_atr_mult * ATR). Exit Short: close > (EMA_slow_mid + exit_atr_mult * ATR)."
    },
    "param_space": {
        "fast_period": {
            "type": "int",
            "low": 5,
            "high": 30,
            "step": 1
        },
        "slow_period": {
            "type": "int",
            "low": 20,
            "high": 60,
            "step": 5
        },
        "adx_period": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 1
        },
        "adx_threshold": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 2
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "exit_atr_mult": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        }
    }
}