{
    "name": "TRIMA_CMO_NATR_Breakout",
    "timeframe": "5m",
    "family": "breakout",
    "description": "Volatility breakout strategy using Triangular Moving Average as dynamic center line and Normalized ATR for adaptive bands. Chande Momentum Oscillator confirms strong directional momentum to avoid false breakouts. Exits when price reverts to the mean or momentum weakens.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "TRIMA",
                "definition": "self.feat.trima(close, timeperiod=20)"
            },
            {
                "name": "NATR",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            },
            {
                "name": "CMO",
                "definition": "self.feat.cmo(close, timeperiod=14)"
            },
            {
                "name": "upper_band",
                "definition": "TRIMA + mult * NATR"
            },
            {
                "name": "lower_band",
                "definition": "TRIMA - mult * NATR"
            }
        ],
        "entry_long": "(close > upper_band) & (close.shift(1) <= upper_band.shift(1)) & (CMO > cmo_entry_threshold)",
        "entry_short": "(close < lower_band) & (close.shift(1) >= lower_band.shift(1)) & (CMO < -cmo_entry_threshold)",
        "exit_logic": "Exit Long: (close < TRIMA) | (CMO < cmo_exit_threshold). Exit Short: (close > TRIMA) | (CMO > -cmo_exit_threshold)."
    },
    "param_space": {
        "trima_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 1
        },
        "natr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "cmo_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "mult": {
            "type": "float",
            "low": 1.0,
            "high": 2.5,
            "step": 0.1
        },
        "cmo_entry_threshold": {
            "type": "int",
            "low": 15,
            "high": 35,
            "step": 5
        },
        "cmo_exit_threshold": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 5
        }
    }
}