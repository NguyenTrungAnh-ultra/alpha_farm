{
    "name": "WilliamsR_NATR_Midprice_Breakout",
    "timeframe": "5m",
    "family": "breakout",
    "description": "Breakout strategy using Midprice-based volatility channel with Williams %R oversold/overbought confirmation and NATR volatility filter. Entries on channel breakout with oscillator extreme, exits when price reverts to midprice.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "midprice",
                "definition": "(high + low) / 2"
            },
            {
                "name": "atr",
                "definition": "ATR(high, low, close, timeperiod=atr_period)"
            },
            {
                "name": "natr",
                "definition": "NATR(high, low, close, timeperiod=atr_period)"
            },
            {
                "name": "upper_band",
                "definition": "midprice + band_multiplier * atr"
            },
            {
                "name": "lower_band",
                "definition": "midprice - band_multiplier * atr"
            },
            {
                "name": "willr",
                "definition": "WILLR(high, low, close, timeperiod=willr_period)"
            }
        ],
        "entry_long": "close > upper_band AND willr < -80 AND natr > min_natr",
        "entry_short": "close < lower_band AND willr > -20 AND natr > min_natr",
        "exit_logic": "Exit long when close < midprice. Exit short when close > midprice."
    },
    "param_space": {
        "willr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "band_multiplier": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        },
        "min_natr": {
            "type": "float",
            "low": 0.5,
            "high": 2.0,
            "step": 0.1
        }
    }
}