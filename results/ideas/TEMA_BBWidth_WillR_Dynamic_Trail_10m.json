{
    "name": "TEMA_BBWidth_WillR_Dynamic_Trail",
    "timeframe": "10m",
    "family": "multi-indicator",
    "description": "Combines TEMA trend direction, Bollinger Band width volatility expansion, and Williams %R oversold/overbought conditions for entry. Exits use trend reversal, Williams %R extreme levels, or ATR-based trailing stop (chandelier). Designed for 2-5 trades per day on VN30F1M 10-minute futures.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "TEMA_fast",
                "definition": "self.feat.tema(close, timeperiod=10)"
            },
            {
                "name": "TEMA_slow",
                "definition": "self.feat.tema(close, timeperiod=30)"
            },
            {
                "name": "BB_upper",
                "definition": "self.feat.bbands(close, timeperiod=20, nbdevup=2, nbdevdn=2)[0]"
            },
            {
                "name": "BB_middle",
                "definition": "self.feat.bbands(close, timeperiod=20, nbdevup=2, nbdevdn=2)[1]"
            },
            {
                "name": "BB_lower",
                "definition": "self.feat.bbands(close, timeperiod=20, nbdevup=2, nbdevdn=2)[2]"
            },
            {
                "name": "BB_width",
                "definition": "(BB_upper - BB_lower) / BB_middle"
            },
            {
                "name": "WillR",
                "definition": "self.feat.willr(high, low, close, timeperiod=14)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "highest_high_5",
                "definition": "self.feat.max(high, timeperiod=5)"
            },
            {
                "name": "lowest_low_5",
                "definition": "self.feat.min(low, timeperiod=5)"
            }
        ],
        "entry_long": "(TEMA_fast > TEMA_slow) & (BB_width > 0.05) & (WillR < -80) & (close > TEMA_fast)",
        "entry_short": "(TEMA_fast < TEMA_slow) & (BB_width > 0.05) & (WillR > -20) & (close < TEMA_fast)",
        "exit_logic": "Exit Long: (WillR > -20) | (TEMA_fast < TEMA_slow) | (low < (highest_high_5 - 2 * ATR)). Exit Short: (WillR < -80) | (TEMA_fast > TEMA_slow) | (high > (lowest_low_5 + 2 * ATR))."
    },
    "param_space": {
        "tema_fast_period": {
            "type": "int",
            "low": 8,
            "high": 15,
            "step": 1
        },
        "tema_slow_period": {
            "type": "int",
            "low": 25,
            "high": 40,
            "step": 1
        },
        "bb_period": {
            "type": "int",
            "low": 15,
            "high": 25,
            "step": 1
        },
        "bb_std": {
            "type": "float",
            "low": 1.5,
            "high": 2.5,
            "step": 0.1
        },
        "willr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "bbw_threshold": {
            "type": "float",
            "low": 0.03,
            "high": 0.1,
            "step": 0.01
        },
        "atr_trail_mult": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        },
        "trailing_period": {
            "type": "int",
            "low": 5,
            "high": 10,
            "step": 1
        }
    }
}