{
    "name": "ROCP_ADXR_Trend_Strength",
    "timeframe": "15m",
    "family": "trend-following",
    "description": "Captures directional momentum bursts using Rate of Change Percentage (ROCP) as primary signal, confirmed by ADXR trend strength and EMA trend alignment. Exits when momentum fades (ROCP changes sign) or trend weakens (ADXR falls below 20). Designed for 15-minute VN30F1M futures with 1-3 high-quality trades per day.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "ROCP",
                "definition": "self.feat.rocp(close, timeperiod=20)"
            },
            {
                "name": "ADXR",
                "definition": "self.feat.adxr(high, low, close, timeperiod=14)"
            },
            {
                "name": "EMA_trend",
                "definition": "self.feat.ema(close, timeperiod=30)"
            }
        ],
        "entry_long": "(ROCP > 0.5) & (ADXR > 25) & (close > EMA_trend)",
        "entry_short": "(ROCP < -0.5) & (ADXR > 25) & (close < EMA_trend)",
        "exit_logic": "Exit Long: (ROCP < 0) | (ADXR < 20). Exit Short: (ROCP > 0) | (ADXR < 20)."
    },
    "param_space": {
        "rocp_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 2
        },
        "rocp_threshold": {
            "type": "float",
            "low": 0.2,
            "high": 1.0,
            "step": 0.1
        },
        "adxr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "adxr_strength_min": {
            "type": "int",
            "low": 20,
            "high": 35,
            "step": 2
        },
        "adxr_exit_threshold": {
            "type": "int",
            "low": 15,
            "high": 25,
            "step": 1
        },
        "ema_period": {
            "type": "int",
            "low": 20,
            "high": 50,
            "step": 5
        }
    }
}