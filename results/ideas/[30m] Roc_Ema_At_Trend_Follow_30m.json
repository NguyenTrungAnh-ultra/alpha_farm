{
    "name": "[30m] Roc_Ema_At_Trend_Follow",
    "timeframe": "30m",
    "family": "trend-following",
    "description": "Trend Following strategy using Rate of Change (ROC) for momentum trigger, EMA(20) for trend direction, and ATR to filter low volatility chop. Entry requires price above EMA with positive ROC acceleration. Exit triggers on close below a volatility-adjusted threshold.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_fast",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "ROC_mom",
                "definition": "self.feat.roc(close, timeperiod=14)"
            },
            {
                "name": "ATR_vol",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > EMA_fast) & (ROC_mom > 0.5)",
        "entry_short": "(close < EMA_fast) & (ROC_mom < -0.5)",
        "exit_long": "(close < (EMA_fast * 1.98))",
        "exit_short": "(close > (EMA_fast * 2.02))"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 5,
            "high": 30,
            "step": 1
        },
        "roc_threshold": {
            "type": "float",
            "low": -1.0,
            "high": 2.0,
            "step": 0.1
        }
    }
}