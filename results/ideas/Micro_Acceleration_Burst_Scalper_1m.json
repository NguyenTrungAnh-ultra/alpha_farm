{
    "name": "Micro_Acceleration_Burst_Scalper",
    "timeframe": "1m",
    "family": "momentum",
    "description": "Ultra-fast scalping strategy capturing directional momentum bursts using price acceleration (difference of linear regression slopes) confirmed by volume surge. Enters on breakout of short-term high/low when acceleration turns positive/negative and volume expands. Exits when acceleration reverses or price violates a volatility-based trailing stop (chandelier exit). Designed for high-noise 1m environment with tight risk management.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "fast_slope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=5)"
            },
            {
                "name": "slow_slope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=10)"
            },
            {
                "name": "price_accel",
                "definition": "fast_slope - slow_slope"
            },
            {
                "name": "volume_sma",
                "definition": "self.feat.sma(volume, timeperiod=5) + 1e-8"
            },
            {
                "name": "volume_surge",
                "definition": "(volume - volume_sma) / volume_sma"
            },
            {
                "name": "atr",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "highest_high",
                "definition": "self.feat.max(high, timeperiod=3)"
            },
            {
                "name": "lowest_low",
                "definition": "self.feat.min(low, timeperiod=3)"
            },
            {
                "name": "trail_high",
                "definition": "self.feat.max(high, timeperiod=10)"
            },
            {
                "name": "trail_low",
                "definition": "self.feat.min(low, timeperiod=10)"
            }
        ],
        "entry_long": "(price_accel > 0) & (volume_surge > 0.5) & (close > highest_high.shift(1))",
        "entry_short": "(price_accel < 0) & (volume_surge > 0.5) & (close < lowest_low.shift(1))",
        "exit_logic": "Exit Long: (price_accel < 0) | (close < (trail_high - 2.0 * atr)). Exit Short: (price_accel > 0) | (close > (trail_low + 2.0 * atr))."
    },
    "param_space": {
        "fast_slope_period": {
            "type": "int",
            "low": 3,
            "high": 8,
            "step": 1
        },
        "slow_slope_period": {
            "type": "int",
            "low": 9,
            "high": 15,
            "step": 1
        },
        "volume_sma_period": {
            "type": "int",
            "low": 3,
            "high": 10,
            "step": 1
        },
        "volume_surge_threshold": {
            "type": "float",
            "low": 0.3,
            "high": 1.5,
            "step": 0.1
        },
        "breakout_lookback": {
            "type": "int",
            "low": 2,
            "high": 5,
            "step": 1
        },
        "atr_period": {
            "type": "int",
            "low": 7,
            "high": 14,
            "step": 1
        },
        "atr_multiplier": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        },
        "trail_lookback": {
            "type": "int",
            "low": 8,
            "high": 12,
            "step": 1
        }
    }
}