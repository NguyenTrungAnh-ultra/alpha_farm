{
    "name": "Slope_RSI_Pullback",
    "timeframe": "60m",
    "family": "momentum",
    "description": "A momentum strategy that enters on pullbacks within a trend, using Linear Regression Slope to confirm direction and RSI for entry timing. Exits when the slope reverses or price crosses below EMA.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "slope_trend",
                "definition": "self.feat.linearreg_slope(close, timeperiod=10)"
            },
            {
                "name": "rsi_momentum",
                "definition": "self.feat.rsi(close, timeperiod=14)"
            }
        ],
        "entry_long": "(linearreg_slope > 0.5) & (rsi < 48)",
        "entry_short": "(linearreg_slope < -0.5) & (rsi > 52)",
        "exit_long": "(close < ema(close, timeperiod=20)) | (slope_trend <= -1)",
        "exit_short": "(close > ema(close, timeperiod=20)) | (slope_trend >= 1)"
    },
    "param_space": {
        "rsi_period": {
            "type": "int",
            "low": 9,
            "high": 25,
            "step": 1
        },
        "slope_threshold_long": {
            "type": "float",
            "low": -0.3,
            "high": 1.5,
            "step": 0.1
        }
    }
}