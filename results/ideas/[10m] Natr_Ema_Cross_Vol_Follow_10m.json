{
    "name": "[10m] Natr_Ema_Cross_Vol_Follow",
    "timeframe": "10m",
    "family": "volatility",
    "description": "Volatility-filtered trend strategy using EMA direction and NATR expansion to confirm momentum. Exits on price reversal or volatility contraction.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ema_trend",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "natr_volatility",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > ema_trend) & (roc(close) > 0.5) & (natr_volatility > self.op.shift(self.feat.atr(natr_volatility), 3))",
        "entry_short": "(close < ema_trend) & (-roc(close) > -1.0) & (natr_volatility > self.op.shift(self.feat.atr(natr_volatility), 3))",
        "exit_long": "(close < ema_trend)",
        "exit_short": "(close > ema_trend)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 10,
            "high": 50,
            "step": 2
        },
        "natr_roll_factor": {
            "type": "float",
            "low": 3.0,
            "high": 8.0,
            "step": 0.5
        }
    }
}