{
    "name": "ZScore_ADX_MeanReversion",
    "timeframe": "60m",
    "family": "mean-reversion",
    "description": "Mean reversion strategy using rolling z-score of price and ADX filter to identify oversold/overbought conditions in ranging markets. Enters long when price is significantly below its mean (z-score < -threshold) and market is ranging (ADX < threshold). Exits when price reverts to mean (z-score > 0) or a trend emerges (ADX rises above exit threshold). Short entries on overbought conditions.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ZSCORE",
                "definition": "self.feat.rolling_zscore(close, timeperiod=param_zscore_period)"
            },
            {
                "name": "ADX",
                "definition": "self.feat.adx(high, low, close, timeperiod=param_adx_period)"
            }
        ],
        "entry_long": "(ZSCORE < -param_zscore_threshold) & (ADX < param_adx_entry_threshold)",
        "entry_short": "(ZSCORE > param_zscore_threshold) & (ADX < param_adx_entry_threshold)",
        "exit_long": "(ZSCORE > 0) | (ADX > param_adx_exit_threshold)",
        "exit_short": "(ZSCORE < 0) | (ADX > param_adx_exit_threshold)"
    },
    "param_space": {
        "param_zscore_period": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 2
        },
        "param_adx_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "param_zscore_threshold": {
            "type": "float",
            "low": 1.5,
            "high": 2.5,
            "step": 0.1
        },
        "param_adx_entry_threshold": {
            "type": "float",
            "low": 15,
            "high": 25,
            "step": 1
        },
        "param_adx_exit_threshold": {
            "type": "float",
            "low": 20,
            "high": 30,
            "step": 1
        }
    }
}