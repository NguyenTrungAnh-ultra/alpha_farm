{
    "name": "[15m] RegFlow_AdX_Follow",
    "timeframe": "15m",
    "family": "trend-following",
    "description": "Trend following strategy using Linear Regression Price as dynamic support, CMF for flow confirmation, and ADX to filter choppy regimes. Avoids simple EMA/MACD crossovers by focusing on price position relative to regression line.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "RegLine",
                "definition": "self.feat.linearreg(close, timeperiod=20)"
            },
            {
                "name": "CMF",
                "definition": "self.feat.cmf(volume, close, timeperiod=14)"
            },
            {
                "name": "ADX",
                "definition": "self.feat.adx(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > RegLine) & (CMF > 0.5)",
        "entry_short": "(close < RegLine) & (CMF < -0.5)",
        "exit_long": "(close <= RegLine)",
        "exit_short": "(close >= RegLine)"
    },
    "param_space": {
        "adx_threshold": {
            "type": "int",
            "low": 15,
            "high": 40,
            "step": 2
        },
        "cmf_period": {
            "type": "int",
            "low": 8,
            "high": 30,
            "step": 2
        }
    }
}