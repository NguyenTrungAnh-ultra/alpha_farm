{
    "name": "[15m] Macd_Cmf_Natr_Trend",
    "timeframe": "15m",
    "family": "trend-following",
    "description": "Uses MACD histogram direction for momentum confirmation, CMF flow accumulation to validate trend strength, and ATR volatility filter to avoid choppy low-volume noise.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "MACD_Hist",
                "definition": "self.feat.macd(close, timeperiod=14)"
            },
            {
                "name": "CMF",
                "definition": "self.feat.cmf(high, low, close, volume, timeperiod=20)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(macd_hist > 5.0) & (cmf > cmf_threshold)",
        "entry_short": "(macd_hist < -5.0) & (cmf < -cmf_threshold)",
        "exit_long": "(close < macd_line) | (macd_hist <= 0)",
        "exit_short": "(close > macd_line) | (macd_hist >= 0)"
    },
    "param_space": {
        "macd_threshold": {
            "type": "float",
            "low": -15.0,
            "high": 20.0,
            "step": 1
        },
        "cmf_threshold": {
            "type": "float",
            "low": 0.3,
            "high": 1.0,
            "step": 0.05
        }
    }
}