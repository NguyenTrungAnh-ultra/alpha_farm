{
    "name": "[60m] TRIX_Mom_Sma_Vol_Follow",
    "timeframe": "60m",
    "family": "momentum|trend-following",
    "description": "Uses TRIX for momentum confirmation aligned with SMA trend direction, filtered by ATR volatility to avoid choppy markets.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "trix_mom",
                "definition": "self.feat.trix(close)"
            },
            {
                "name": "sma_trend",
                "definition": "self.feat.sma(close, timeperiod=20)"
            },
            {
                "name": "atr_vol",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(trix_mom > 0.5) & (close > sma_trend)",
        "entry_short": "(trix_mom < -0.5) & (close < sma_trend)",
        "exit_long": "(trix_mom <= 0) | (close < sma_trend)",
        "exit_short": "(trix_mom >= 0) | (close > sma_trend)"
    },
    "param_space": {
        "sma_period": {
            "type": "int",
            "low": 15,
            "high": 40,
            "step": 2
        },
        "atr_threshold": {
            "type": "float",
            "low": 0.8,
            "high": 3.0,
            "step": 0.1
        }
    }
}