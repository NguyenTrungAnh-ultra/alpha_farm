{
    "name": "[30m] ChanBreak_Slope_Bb_Trail",
    "timeframe": "30m",
    "family": "channel",
    "description": "Channel breakout strategy using dynamic price bands and linear regression slope confirmation, avoiding volume-based indicators to prevent division-by-zero errors on zero-volume bars.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "BB_Upper",
                "definition": "self.feat.bbands(close, timeperiod=20).upper"
            },
            {
                "name": "BB_Middle",
                "definition": "self.feat.bbands(close, timeperiod=20).middle"
            },
            {
                "name": "Slope_Close",
                "definition": "linearreg_slope(close, period=15)"
            },
            {
                "name": "Band_Width",
                "definition": "bb_upper - bb_middle"
            }
        ],
        "entry_long": "(close > BB_Upper) & (Slope_Close >= 0)",
        "entry_short": "(close < BB_Middle) & (Slope_Close <= 0)",
        "exit_long": "(close < BB_Middle)",
        "exit_short": "(close > BB_Middle)"
    },
    "param_space": {
        "bb_period": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 2
        },
        "slope_period": {
            "type": "int",
            "low": 8,
            "high": 25,
            "step": 1
        }
    }
}