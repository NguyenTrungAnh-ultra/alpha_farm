{
    "name": "[60m] LinearReg_Slope_Stochf_Trend",
    "timeframe": "60m",
    "family": "trend-following|momentum",
    "description": "Trend Following strategy using Linear Regression Slope for direction and Stochastic Fast for momentum confirmation, filtered by ATR volatility.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "LinearReg_Slope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=20)"
            },
            {
                "name": "StochFast",
                "definition": "self.feat.stochf(high, low, close)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(LinearReg_Slope > 0.5) & (StochFast < 30)",
        "entry_short": "(LinearReg_Slope < -0.5) & (StochFast > 70)",
        "exit_long": "(close < LinearReg(close, timeperiod=20))",
        "exit_short": "(close > LinearReg(close, timeperiod=20))"
    },
    "param_space": {
        "LinearReg_Period": {
            "type": "int",
            "low": 10,
            "high": 35,
            "step": 1
        },
        "StochFast_K": {
            "type": "float",
            "low": 2.0,
            "high": 8.0,
            "step": 0.5
        }
    }
}