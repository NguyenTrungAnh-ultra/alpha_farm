{
    "name": "Session_Wma_Adx_Trend_Follow",
    "timeframe": "30m",
    "family": "trend-following",
    "description": "A trend-following strategy for VN30 Index Futures that uses Weighted Moving Average (WMA) to identify direction and ADX to filter out low-volatility choppy markets. It prioritizes major trends during active sessions by requiring high volatility strength before entry.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "WMA_fast",
                "definition": "self.feat.wma(close, timeperiod=10)"
            },
            {
                "name": "ADX_Regime",
                "definition": "self.feat.adx(high, low, close, volume, timeperiod=14)"
            }
        ],
        "entry_long": "(close >= WMA_fast) & (ADX_Regime > 25)",
        "entry_short": "(close <= WMA_fast) & (ADX_Regime > 25)",
        "exit_long": "(close < WMA_fast)",
        "exit_short": "(close > WMA_fast)"
    },
    "param_space": {
        "wma_period": {
            "type": "int",
            "low": 5,
            "high": 30,
            "step": 1
        },
        "adx_threshold": {
            "type": "float",
            "low": 20.0,
            "high": 40.0,
            "step": 1.0
        }
    }
}