{
    "name": "T3_ADX_Momentum_Breakout",
    "timeframe": "10m",
    "family": "multi-indicator",
    "description": "Uses T3 exponential trend direction combined with EMA confirmation, filtered by ADX strength to avoid choppy sideways markets. Avoids volume division errors.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_fast",
                "definition": "self.feat.ema(close, timeperiod=15)"
            },
            {
                "name": "T3_Trend",
                "definition": "self.feat.t3(close, timeperiod=20)"
            },
            {
                "name": "ADX_Strength",
                "definition": "self.feat.adx(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > EMA_fast) & (linearreg_slope(T3_Trend, 5) >= slope_min)",
        "entry_short": "(close < EMA_fast) & (linearreg_slope(T3_Trend, 5) <= -slope_min)",
        "exit_long": "(natr(high, low, close, timeperiod=14) <= natr_threshold) | (adx_Strength <= adx_max)",
        "exit_short": "(natr(high, low, close, timeperiod=14) >= natr_high_limit) & (adx_Strength < 25)"
    },
    "param_space": {
        "slope_min": {
            "type": "float",
            "low": -0.5,
            "high": 0.5,
            "step": 0.1
        },
        "natr_threshold": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 5
        }
    }
}