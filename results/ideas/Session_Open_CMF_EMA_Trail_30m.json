{
    "name": "Session_Open_CMF_EMA_Trail",
    "timeframe": "30m",
    "family": "session-based",
    "description": "Intraday trend-following strategy that uses Session Open strength (current bar close vs open) and Cumulative Money Flow to confirm momentum, filtered by EMA direction. Avoids time-dependent logic but relies on price structure typical of session opens.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_fast",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "CMF",
                "definition": "self.feat.cmf(high, low, close, volume, timeperiod=14)"
            }
        ],
        "entry_long": "(close > open_price) & (cmf > 0.5)",
        "entry_short": "(close < open_price) & (cmf < -0.5)",
        "exit_long": "(ema >= close) or (cmf <= 0)",
        "exit_short": "(ema <= close) or (cmf >= 0)"
    },
    "param_space": {
        "EMA_Period": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 2
        },
        "CMF_Threshold": {
            "type": "float",
            "low": -1.0,
            "high": 1.0,
            "step": 0.1
        }
    }
}