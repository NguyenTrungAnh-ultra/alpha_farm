{
    "name": "Kama_Atr_Breakout_Trend",
    "timeframe": "15m",
    "family": "breakout",
    "description": "Breakout strategy using KAMA (Kaufman Adaptive Moving Average) as the adaptive middle line and ATR-based volatility bands. Entry triggers when price closes above the upper band (long) or below the lower band (short), confirmed by ADX > threshold to ensure a trending regime. Exits occur when price crosses back below/above the KAMA midline, capturing the core trend while avoiding whipsaws.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "KAMA",
                "definition": "self.feat.kama(close, timeperiod=kama_period)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=atr_period)"
            },
            {
                "name": "ADX",
                "definition": "self.feat.adx(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > (KAMA + multiplier * ATR)) & (ADX > adx_threshold)",
        "entry_short": "(close < (KAMA - multiplier * ATR)) & (ADX > adx_threshold)",
        "exit_long": "close < KAMA",
        "exit_short": "close > KAMA"
    },
    "param_space": {
        "kama_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 1
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "multiplier": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        },
        "adx_threshold": {
            "type": "int",
            "low": 20,
            "high": 30,
            "step": 1
        }
    }
}