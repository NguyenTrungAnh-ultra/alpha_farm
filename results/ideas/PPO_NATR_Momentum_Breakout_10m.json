{
    "name": "PPO_NATR_Momentum_Breakout",
    "timeframe": "10m",
    "family": "momentum",
    "description": "Captures momentum shifts using Price Momentum Oscillator (PPO) combined with volatility confirmation via Normalized ATR. Enters on PPO crossover up during expanding volatility regimes, exits when momentum reverses.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "ppo_val",
                "definition": "self.feat.ppo(close, timeperiod=14)"
            },
            {
                "name": "natr_vol",
                "definition": "self.feat.natr(high, low, close, timeperiod=param_nATR_period)"
            }
        ],
        "entry_long": "(crossed_above(ppo_val, shift(ppo_val)) & (natr_vol > natr_vol.shift(1)))",
        "entry_short": "(crossed_below(ppo_val, shift(ppo_val)) & (natr_vol < natr_vol.shift(1)))",
        "exit_long": "(crossed_below(ppo_val, shift(ppo_val)))",
        "exit_short": "(crossed_above(ppo_val, shift(ppo_val)))"
    },
    "param_space": {
        "nATR_period": {
            "type": "int",
            "low": 10,
            "high": 40,
            "step": 5
        }
    }
}