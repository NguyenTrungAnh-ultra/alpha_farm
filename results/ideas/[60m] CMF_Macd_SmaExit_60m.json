{
    "name": "[60m] CMF_Macd_SmaExit",
    "timeframe": "60m",
    "family": "momentum",
    "description": "A momentum strategy using Cumulative Volume Flow (CMF) to confirm MACD trend direction, exiting on price reversal relative to a moving average.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "cmf_flow",
                "definition": "self.feat.cmf(high, low, close)"
            },
            {
                "name": "macd_line",
                "definition": "self.feat.macd(close)"
            },
            {
                "name": "sma_trend",
                "definition": "self.feat.sma(close, timeperiod=20)"
            }
        ],
        "entry_long": "(cmf_flow > 0.5) & (macd_line > self.op.max(macd_line)) & (close >= sma_trend)",
        "entry_short": "(cmf_flow < -0.5) & (macd_line < self.op.min(macd_line)) & (close <= sma_trend)",
        "exit_long": "(close < sma_trend) | (macd_line < 0)",
        "exit_short": "(close > sma_trend) | (macd_line > 0)"
    },
    "param_space": {
        "cmf_threshold": {
            "type": "float",
            "low": -1.5,
            "high": 2.5,
            "step": 0.1
        },
        "sma_period": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 1
        }
    }
}