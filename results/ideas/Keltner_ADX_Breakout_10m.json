{
    "name": "Keltner_ADX_Breakout",
    "timeframe": "10m",
    "family": "breakout",
    "description": "Breakout of Keltner Channel (middle EMA, upper/lower based on ATR) with ADX trend strength filter. Enter long when price crosses above upper band and ADX above threshold; short when crosses below lower band and ADX above threshold. Exit when price crosses back into the channel (below middle for long, above middle for short).",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ema_mid",
                "definition": "self.feat.ema(close, timeperiod=ema_period)"
            },
            {
                "name": "atr_val",
                "definition": "self.feat.atr(high, low, close, timeperiod=atr_period)"
            },
            {
                "name": "upper",
                "definition": "ema_mid + multiplier * atr_val"
            },
            {
                "name": "lower",
                "definition": "ema_mid - multiplier * atr_val"
            },
            {
                "name": "adx",
                "definition": "self.feat.adx(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > upper) & (adx > adx_threshold)",
        "entry_short": "(close < lower) & (adx > adx_threshold)",
        "exit_long": "(close < ema_mid)",
        "exit_short": "(close > ema_mid)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 1
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "multiplier": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.5
        },
        "adx_threshold": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 5
        }
    }
}