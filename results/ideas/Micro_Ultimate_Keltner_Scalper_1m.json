{
    "name": "Micro_Ultimate_Keltner_Scalper",
    "timeframe": "1m",
    "family": "mean-reversion",
    "description": "Mean-reversion scalper for 1m timeframe using Ultimate Oscillator (ultosc) to detect oversold/overbought conditions and Keltner Channel (based on ATR) as dynamic support/resistance. Enters long when price crosses below lower Keltner band and ultosc is below oversold threshold, confirmed by volume surge. Enters short when price crosses above upper Keltner band and ultosc is above overbought threshold, confirmed by volume surge. Exits when price returns to middle band or momentum neutralizes.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "Keltner_Middle",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Keltner_Upper",
                "definition": "Keltner_Middle + 2.0 * ATR"
            },
            {
                "name": "Keltner_Lower",
                "definition": "Keltner_Middle - 2.0 * ATR"
            },
            {
                "name": "UltOsc",
                "definition": "self.feat.ultosc(high, low, close, timeperiod1=7, timeperiod2=14, timeperiod3=28)"
            },
            {
                "name": "VolSMA",
                "definition": "self.feat.sma(volume, timeperiod=5) + 1e-8"
            }
        ],
        "entry_long": "(close < Keltner_Lower) & (close.shift(1) >= Keltner_Lower.shift(1)) & (UltOsc < 20) & (volume > VolSMA * 1.5)",
        "entry_short": "(close > Keltner_Upper) & (close.shift(1) <= Keltner_Upper.shift(1)) & (UltOsc > 80) & (volume > VolSMA * 1.5)",
        "exit_logic": "Exit Long: (close >= Keltner_Middle) | (UltOsc > 50). Exit Short: (close <= Keltner_Middle) | (UltOsc < 50)."
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 2
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 2
        },
        "keltner_mult": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        },
        "ult_oversold": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 5
        },
        "ult_overbought": {
            "type": "int",
            "low": 70,
            "high": 90,
            "step": 5
        },
        "vol_mult": {
            "type": "float",
            "low": 1.2,
            "high": 2.0,
            "step": 0.1
        }
    }
}