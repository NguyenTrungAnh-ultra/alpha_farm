{
    "name": "Micro_TRIMA_CMO_Volatility_Scalper",
    "timeframe": "1m",
    "family": "multi-indicator",
    "description": "Ultra-fast scalping strategy for 1-minute VN30F1M using Triangular Moving Average (TRIMA) as dynamic support/resistance, Chande Momentum Oscillator (CMO) for oversold/overbought extremes, and ATR-based trailing exit. Requires volume surge to confirm micro momentum bursts while filtering noise.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "TRIMA",
                "definition": "TRIMA(close, timeperiod=10)"
            },
            {
                "name": "CMO",
                "definition": "CMO(close, timeperiod=10)"
            },
            {
                "name": "ATR",
                "definition": "ATR(high, low, close, timeperiod=10)"
            },
            {
                "name": "Volume_SMA",
                "definition": "SMA(volume, timeperiod=20)"
            },
            {
                "name": "HighestHigh",
                "definition": "MAX(high, timeperiod=10)"
            },
            {
                "name": "LowestLow",
                "definition": "MIN(low, timeperiod=10)"
            }
        ],
        "entry_long": "(close > TRIMA) AND (CMO < -35) AND (volume > Volume_SMA * 1.2) AND (ATR > SMA(ATR, 20) * 0.5)",
        "entry_short": "(close < TRIMA) AND (CMO > 35) AND (volume > Volume_SMA * 1.2) AND (ATR > SMA(ATR, 20) * 0.5)",
        "exit_logic": "Exit LONG when (close < (HighestHigh - 1.5 * ATR)) OR (CMO > 20). Exit SHORT when (close > (LowestLow + 1.5 * ATR)) OR (CMO < -20)."
    },
    "param_space": {
        "trima_period": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "cmo_period": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "cmo_threshold": {
            "type": "int",
            "low": 30,
            "high": 50,
            "step": 5
        },
        "atr_period": {
            "type": "int",
            "low": 7,
            "high": 14,
            "step": 1
        },
        "atr_multiplier": {
            "type": "float",
            "low": 1.0,
            "high": 2.5,
            "step": 0.1
        },
        "volume_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 2
        },
        "volume_surge": {
            "type": "float",
            "low": 1.0,
            "high": 1.8,
            "step": 0.1
        }
    }
}