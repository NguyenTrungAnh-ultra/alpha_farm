{
    "name": "PPO_LinearSlope_Momentum_Flow",
    "timeframe": "10m",
    "family": "momentum",
    "description": "Enters long when PPO crosses above zero with positive linear regression slope and sufficient ATR volatility, exits when PPO crosses below zero. Short trades use opposite logic. Uses momentum confirmation and volatility filter to avoid choppy markets.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "PPO",
                "definition": "self.feat.ppo(close, fastperiod=ppo_fast, slowperiod=ppo_slow, signalperiod=ppo_signal)"
            },
            {
                "name": "LinRegSlope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=linreg_period)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=atr_period)"
            }
        ],
        "entry_long": "(PPO > 0) & (LinRegSlope > 0) & (ATR > atr_threshold)",
        "entry_short": "(PPO < 0) & (LinRegSlope < 0) & (ATR > atr_threshold)",
        "exit_long": "self.op.crossed_below(PPO, 0)",
        "exit_short": "self.op.crossed_above(PPO, 0)"
    },
    "param_space": {
        "ppo_fast": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "ppo_slow": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 2
        },
        "ppo_signal": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "linreg_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 2
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "atr_threshold": {
            "type": "float",
            "low": 3.0,
            "high": 15.0,
            "step": 1.0
        }
    }
}