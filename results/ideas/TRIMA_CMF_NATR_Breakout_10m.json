{
    "name": "TRIMA_CMF_NATR_Breakout",
    "timeframe": "10m",
    "family": "breakout",
    "description": "Uses TRIMA for trend direction, CMF for volume flow confirmation, and NATR to filter volatility regimes. Entry on breakout of price above TRIMA with positive money flow in active market.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "TRIMA_fast",
                "definition": "self.feat.trima(close, timeperiod=30)"
            },
            {
                "name": "CMF_Flow",
                "definition": "self.feat.cmf(high, low, close, volume)"
            },
            {
                "name": "NATR_Volatility",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > TRIMA_fast) & (CMF_Flow >= 0)",
        "entry_short": "(close < TRIMA_fast) & (CMF_Flow <= 0)",
        "exit_long": "(close < TRIMA_fast)",
        "exit_short": "(close > TRIMA_fast)"
    },
    "param_space": {
        "trima_period": {
            "type": "int",
            "low": 20,
            "high": 50,
            "step": 1
        },
        "natr_threshold": {
            "type": "float",
            "low": 0.5,
            "high": 3.0,
            "step": 0.1
        }
    }
}