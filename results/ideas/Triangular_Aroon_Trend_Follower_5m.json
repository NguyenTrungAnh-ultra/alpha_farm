{
    "name": "Triangular_Aroon_Trend_Follower",
    "timeframe": "5m",
    "family": "trend-following",
    "description": "Uses Triangular Moving Average as dynamic trend filter and Aroon Oscillator to confirm directional strength. Entries occur when price is on the same side of TRIMA as the Aroon Oscillator sign. Exits use an ATR-based trailing stop based on rolling highest high (long) or lowest low (short).",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "TRIMA",
                "definition": "self.feat.trima(close, timeperiod=20)"
            },
            {
                "name": "AROONOSC",
                "definition": "self.feat.aroonosc(high, low, timeperiod=14)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "rolling_high_max",
                "definition": "high.rolling(window=10).max()"
            },
            {
                "name": "rolling_low_min",
                "definition": "low.rolling(window=10).min()"
            }
        ],
        "entry_long": "(AROONOSC > 0) & (close > TRIMA)",
        "entry_short": "(AROONOSC < 0) & (close < TRIMA)",
        "exit_logic": "Exit Long: close < (rolling_high_max - 2.0 * ATR). Exit Short: close > (rolling_low_min + 2.0 * ATR)."
    },
    "param_space": {
        "trima_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 1
        },
        "aroon_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 1
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "trailing_period": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "atr_multiplier": {
            "type": "float",
            "low": 1.0,
            "high": 3.0,
            "step": 0.1
        }
    }
}