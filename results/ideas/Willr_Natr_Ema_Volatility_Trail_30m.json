{
    "name": "Willr_Natr_Ema_Volatility_Trail",
    "timeframe": "30m",
    "family": "breakout",
    "description": "Captures momentum breakouts when price is oversold relative to EMA but volatility expands, exiting on volatility contraction.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "ema_20",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "natr_vol",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > ema_20) & (willr < -85)",
        "entry_short": "(close < ema_20) & (willr > 95)",
        "exit_long": "(natr_vol < threshold_natr)",
        "exit_short": "(natr_vol < threshold_natr)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 10,
            "high": 40,
            "step": 5
        },
        "willr_threshold_long": {
            "type": "float",
            "low": -90.0,
            "high": -70.0,
            "step": 2.0
        }
    }
}