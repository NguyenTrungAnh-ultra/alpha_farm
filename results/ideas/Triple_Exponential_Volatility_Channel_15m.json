{
    "name": "Triple_Exponential_Volatility_Channel",
    "timeframe": "15m",
    "family": "channel",
    "description": "A high-quality 15-minute swing intraday strategy utilizing a Triple Exponential Moving Average (TEMA) channel envelope. The strategy addresses the distinct regime traits of the VN30F1M contract by measuring structural volatility width via a normalized standard deviation filter to bypass choppy consolidation zones. Positions are entered when price aggressively exits the structural TEMA channel envelope. Vectorized tracking exits are established via an adaptive dynamic mid-price anchor combined with an ATR factor to guarantee safe intraday execution.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "TEMA_Basis",
                "definition": "self.feat.t3(close, timeperiod=tema_period)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=atr_period)"
            },
            {
                "name": "Upper_Channel",
                "definition": "TEMA_Basis + (channel_mult * ATR)"
            },
            {
                "name": "Lower_Channel",
                "definition": "TEMA_Basis - (channel_mult * ATR)"
            },
            {
                "name": "Normalized_StdDev",
                "definition": "self.feat.stddev(close, timeperiod=20) / (self.feat.midprice(high, low, timeperiod=20) + 1e-8)"
            },
            {
                "name": "Dynamic_Mid",
                "definition": "self.feat.midprice(high, low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(Normalized_StdDev > vol_min) & (close > Upper_Channel)",
        "entry_short": "(Normalized_StdDev > vol_min) & (close < Lower_Channel)",
        "exit_logic": "Exit Long: (close < Dynamic_Mid - 0.5 * ATR). Exit Short: (close > Dynamic_Mid + 0.5 * ATR)."
    },
    "param_space": {
        "tema_period": {
            "type": "int",
            "low": 14,
            "high": 35,
            "step": 1
        },
        "atr_period": {
            "type": "int",
            "low": 14,
            "high": 28,
            "step": 1
        },
        "channel_mult": {
            "type": "float",
            "low": 1.2,
            "high": 2.6,
            "step": 0.1
        },
        "vol_min": {
            "type": "float",
            "low": 0.001,
            "high": 0.005,
            "step": 0.0005
        },
        "exit_period": {
            "type": "int",
            "low": 10,
            "high": 22,
            "step": 2
        }
    }
}