{
    "name": "MeanReversion_Zscore_RSI_ADX_Filter",
    "timeframe": "30m",
    "family": "mean-reversion",
    "description": "A mean reversion strategy that trades price deviations from a rolling statistical baseline (Z-Score) confirmed by momentum exhaustion, filtered to avoid strong trend regimes using ADX.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "rolling_zscore",
                "definition": "self.feat.rolling_zscore(close, timeperiod=20)"
            },
            {
                "name": "rsi_14",
                "definition": "self.feat.rsi(high, low, close, timeperiod=14)"
            },
            {
                "name": "adx_14",
                "definition": "self.feat.adx(high, low, close, timeperiod=14)"
            },
            {
                "name": "rolling_adr_mean",
                "definition": "self.feat.ema(self.feat.atr(high, low, close, timeperiod=14), timeperiod=20)"
            }
        ],
        "entry_long": "(abs(adx_14) < 35) & (rolling_zscore < -2.0) & (rsi_14 <= 30)",
        "entry_short": "(abs(adx_14) < 35) & (rolling_zscore > 2.0) & (rsi_14 >= 70)",
        "exit_long": "(rolling_zscore >= -1.0) | (closing_price_crosses_mean)",
        "exit_short": "(rolling_zscore <= 1.0) | (closing_price_crosses_mean)"
    },
    "param_space": {
        "zscore_threshold_low": {
            "type": "float",
            "low": -2.5,
            "high": -3.0,
            "step": 0.1
        },
        "rsi_oversold_level": {
            "type": "int",
            "low": 28,
            "high": 40,
            "step": 1
        }
    }
}