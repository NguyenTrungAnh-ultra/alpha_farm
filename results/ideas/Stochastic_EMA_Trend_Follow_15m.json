{
    "name": "Stochastic_EMA_Trend_Follow",
    "timeframe": "15m",
    "family": "trend-following",
    "description": "Uses Fast Stochastic Oscillator to confirm momentum on EMA trend direction, avoiding ADX/MACD heavy filters found in other strategies. Entry requires Price above EMA and Stoch cross up from neutral zone.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_fast",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "Stoch_Fast",
                "definition": "self.feat.stoch(high, low, close)"
            }
        ],
        "entry_long": "(close > EMA_fast) & (op.crossed_above(Stoch_Fast))",
        "entry_short": "(close < EMA_fast) & (op.crossed_below(Stoch_Fast))",
        "exit_long": "(close < EMA_fast)",
        "exit_short": "(close > EMA_fast)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 10,
            "high": 50,
            "step": 2
        },
        "stoch_k1": {
            "type": "float",
            "low": 3.0,
            "high": 9.0,
            "step": 0.5
        }
    }
}