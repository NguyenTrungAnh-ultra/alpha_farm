{
    "name": "Volatility_Squeeze_Kama_Trend",
    "timeframe": "15m",
    "family": "trend-following",
    "description": "A high-quality swing intraday strategy designed for the 15-minute timeframe. It utilizes a Bollinger Bands and Keltner Channel squeeze comparison to identify structural consolidation regimes and prevent whipsaws. Once the squeeze releases (volatility expansion), the Kaufman Adaptive Moving Average (KAMA) defines the structural trend direction to establish positions. Clean vector-based exits are triggered when the price crosses the standard trailing Parabolic SAR, optimizing profit capture over broader intraday moves.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "BB_Upper",
                "definition": "self.feat.bbands(close, timeperiod=bb_period, nbdevup=bb_mult, nbdevdn=bb_mult)[0]"
            },
            {
                "name": "BB_Lower",
                "definition": "self.feat.bbands(close, timeperiod=bb_period, nbdevup=bb_mult, nbdevdn=bb_mult)[2]"
            },
            {
                "name": "EMA_mid",
                "definition": "self.feat.ema(close, timeperiod=bb_period)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=bb_period)"
            },
            {
                "name": "KC_Upper",
                "definition": "EMA_mid + (kc_mult * ATR)"
            },
            {
                "name": "KC_Lower",
                "definition": "EMA_mid - (kc_mult * ATR)"
            },
            {
                "name": "Squeeze_Active",
                "definition": "((BB_Upper - BB_Lower) < (KC_Upper - KC_Lower))"
            },
            {
                "name": "KAMA",
                "definition": "self.feat.kama(close, timeperiod=kama_period)"
            },
            {
                "name": "SAR",
                "definition": "self.feat.sar(high, low, acceleration=sar_acc, maximum=sar_max)"
            }
        ],
        "entry_long": "(Squeeze_Active == 0) & (close > KAMA) & (close > SAR)",
        "entry_short": "(Squeeze_Active == 0) & (close < KAMA) & (close < SAR)",
        "exit_logic": "Exit Long: (close < SAR). Exit Short: (close > SAR)."
    },
    "param_space": {
        "bb_period": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 1
        },
        "bb_mult": {
            "type": "float",
            "low": 1.8,
            "high": 2.4,
            "step": 0.1
        },
        "kc_mult": {
            "type": "float",
            "low": 1.3,
            "high": 1.9,
            "step": 0.1
        },
        "kama_period": {
            "type": "int",
            "low": 20,
            "high": 50,
            "step": 2
        },
        "sar_acc": {
            "type": "float",
            "low": 0.01,
            "high": 0.04,
            "step": 0.01
        },
        "sar_max": {
            "type": "float",
            "low": 0.1,
            "high": 0.3,
            "step": 0.05
        }
    }
}