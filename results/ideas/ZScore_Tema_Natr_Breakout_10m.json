{
    "name": "ZScore_Tema_Natr_Breakout",
    "timeframe": "10m",
    "family": "trend-following",
    "description": "A trend-following strategy using TEMA for direction, Rolling Z-Score to confirm price deviation strength relative to mean (momentum), and NATR to filter volatility expansion. Exits on reversal or significant volatility contraction.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "Tema_Trend",
                "definition": "self.feat.tema(close, timeperiod=20)"
            },
            {
                "name": "ZScore_Momentum",
                "definition": "self.feat.rolling_zscore(close, period=15)"
            },
            {
                "name": "Natr_Volatility",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > Tema_Trend) & (ZScore_Momentum > 0.8)",
        "entry_short": "(close < Tema_Trend) & (ZScore_Momentum < -0.8)",
        "exit_long": "(close <= Tema_Trend) | (Natr_Volatility < rolling_min(Natr_Volatility, period=15))",
        "exit_short": "(close >= Tema_Trend) | (Natr_Volatility < rolling_min(Natr_Volatility, period=15))"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 2
        },
        "zscore_threshold": {
            "type": "float",
            "low": -2.0,
            "high": 5.0,
            "step": 0.5
        }
    }
}