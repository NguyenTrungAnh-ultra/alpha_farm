{
    "name": "NatRoc_VolExpansion_Momentum_Follow",
    "timeframe": "30m",
    "family": "volatility",
    "description": "Captures momentum when normalized ATR expands beyond its mean, confirming trend strength with EMA alignment. Uses volatility expansion rate to filter entry signals.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "natr",
                "definition": "self.feat.natr(high, low, close, timeperiod=20)"
            },
            {
                "name": "ema",
                "definition": "self.feat.ema(close, timeperiod=14)"
            },
            {
                "name": "roc",
                "definition": "self.op.pct_change(self.feat.close)"
            }
        ],
        "entry_long": "(natr > rolling_mean(natr)) & (close >= ema)",
        "entry_short": "(rolling_mean(natr) - natr) > 0.1 * natr & close <= ema",
        "exit_long": "(close < ema) | (roc <= 0)",
        "exit_short": "(close > ema) | (roc >= 0)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 8,
            "high": 40,
            "step": 1
        },
        "natr_period": {
            "type": "int",
            "low": 5,
            "high": 30,
            "step": 2
        }
    }
}