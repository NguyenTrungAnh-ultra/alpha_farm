{
    "name": "[60m] EMA_Trend_Piercing_Cross",
    "timeframe": "60m",
    "family": "pattern-based",
    "description": "Uses EMA trend direction and Piercing pattern confirmation for entry, exits on price reversal relative to EMA.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "EMA_fast",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "Slope_Filter",
                "definition": "self.feat.linearreg_slope(close, timeperiod=15)"
            }
        ],
        "entry_long": "(close > EMA_fast) & (linearreg_slope > 0)",
        "entry_short": "(close < EMA_fast) & (linearreg_slope < -2.0)",
        "exit_long": "(close < EMA_fast)",
        "exit_short": "(close > EMA_fast)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 14,
            "high": 35,
            "step": 2
        },
        "slope_threshold": {
            "type": "float",
            "low": -0.5,
            "high": 0.5,
            "step": 0.1
        }
    }
}