{
    "name": "StochRSI_ATR_Trailing_Momentum",
    "timeframe": "15m",
    "family": "trend-following",
    "description": "Trend-following strategy using StochRSI oversold/overbought signals with EMA trend filter and ADX regime filter. Exits using ATR-based trailing stop on rolling high/low to capture swing moves while avoiding noise.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "EMA_trend",
                "definition": "self.feat.ema(close, timeperiod=ema_period)"
            },
            {
                "name": "ADX_strength",
                "definition": "self.feat.adx(high, low, close, timeperiod=adx_period)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "StochRSI_K",
                "definition": "self.feat.stochrsi(close, timeperiod=14, fastk_period=stoch_k, fastd_period=3)"
            }
        ],
        "entry_long": "(StochRSI_K < 20) & (close > EMA_trend) & (ADX_strength > 25)",
        "entry_short": "(StochRSI_K > 80) & (close < EMA_trend) & (ADX_strength > 25)",
        "exit_logic": "Exit Long: close < (high.rolling(window=trail_window).max().shift(1) - (ATR.shift(1) * atr_mult)). Exit Short: close > (low.rolling(window=trail_window).min().shift(1) + (ATR.shift(1) * atr_mult))."
    },
    "param_space": {
        "stoch_k": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "ema_period": {
            "type": "int",
            "low": 30,
            "high": 60,
            "step": 5
        },
        "adx_period": {
            "type": "int",
            "low": 14,
            "high": 20,
            "step": 1
        },
        "atr_mult": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        },
        "trail_window": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 2
        }
    }
}