{
    "name": "[10m] LinearReg_Slope_CCI_Momentum_Continuation",
    "timeframe": "10m",
    "family": "trend-following",
    "description": "Uses linear regression slope for trend direction and CCI momentum filter to confirm entries, with volatility-based exit logic.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "trend_slope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=20)"
            },
            {
                "name": "cci_filter",
                "definition": "self.feat.cci(high, low, close, timeperiod=14)"
            },
            {
                "name": "natr_exit",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(trend_slope > 0.5) & (cci_filter_crossed_above(-20))",
        "entry_short": "(trend_slope < -0.5) & (cci_filter_crossed_below(20))",
        "exit_long": "(close < close_prev * (1 + natr_exit * 0.3)) | (trend_slope <= 0)",
        "exit_short": "(close > close_prev * (1 - natr_exit * 0.3)) | (trend_slope >= 0)"
    },
    "param_space": {
        "slope_threshold": {
            "type": "float",
            "low": 0.5,
            "high": 2.0,
            "step": 0.1
        },
        "cci_cross_level": {
            "type": "int|float",
            "low": -30,
            "high": 20,
            "step": 5
        }
    }
}