{
    "name": "[10m] T3_NATR_Trend_Follow",
    "timeframe": "10m",
    "family": "trend-following",
    "description": "Trend following strategy using Triple Exponential (T3) for trend direction and NATR to filter volatility noise. Entry on price crossing above T3 when volatility is active, exit on reversal.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "T3_Signal",
                "definition": "self.feat.t3(close)"
            },
            {
                "name": "NATR",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > T3_Signal) & (T3_Signal > 0)",
        "entry_short": "(close < T3_Signal) & (T3_Signal < 0)",
        "exit_long": "(close <= T3_Signal) | (NATR < NATR.shift(1))",
        "exit_short": "(close >= T3_Signal) | (NATR > NATR.shift(1))"
    },
    "param_space": {
        "T3_Period": {
            "type": "int",
            "low": 5,
            "high": 20,
            "step": 1
        },
        "NATR_Filter_Threshold": {
            "type": "float",
            "low": 0.8,
            "high": 2.0,
            "step": 0.1
        }
    }
}