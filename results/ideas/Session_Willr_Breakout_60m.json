{
    "name": "Session_Willr_Breakout",
    "timeframe": "60m",
    "family": "session-based",
    "description": "Breakout strategy that uses the high/low of the previous session (rolling window) as a range, with Williams %R to confirm momentum and ATR to filter low-volatility periods. Entries occur when price breaks the range with strong overbought/oversold signals; exits happen when price returns to the session midpoint.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "session_high",
                "definition": "self.op.shift(self.feat.rolling_max(high, timeperiod=N), 1)"
            },
            {
                "name": "session_low",
                "definition": "self.op.shift(self.feat.rolling_min(low, timeperiod=N), 1)"
            },
            {
                "name": "session_mid",
                "definition": "(session_high + session_low) / 2"
            },
            {
                "name": "willr",
                "definition": "self.feat.willr(high, low, close, timeperiod=14)"
            },
            {
                "name": "atr",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > session_high) & (willr > -20) & (atr > atr_threshold)",
        "entry_short": "(close < session_low) & (willr < -80) & (atr > atr_threshold)",
        "exit_long": "(close < session_mid)",
        "exit_short": "(close > session_mid)"
    },
    "param_space": {
        "N": {
            "type": "int",
            "low": 3,
            "high": 8,
            "step": 1
        },
        "atr_threshold": {
            "type": "float",
            "low": 0.5,
            "high": 3.0,
            "step": 0.1
        }
    }
}