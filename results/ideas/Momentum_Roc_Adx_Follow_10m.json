{
    "name": "Momentum_Roc_Adx_Follow",
    "timeframe": "10m",
    "family": "momentum",
    "description": "A momentum strategy that enters when price is above the trend EMA and ROC indicates acceleration, filtered by ADX strength. Exits on momentum reversal confirmed with dynamic volatility context.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "EMA_Trend",
                "definition": "self.feat.ema(close, timeperiod=20)"
            },
            {
                "name": "ROC_Mom",
                "definition": "self.feat.roc(close, timeperiod=14)"
            },
            {
                "name": "ADX_Strength",
                "definition": "self.feat.adx(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(close > EMA_Trend) & (ROC_Mom >= 0.5)",
        "exit_long": "(close < EMA_Trend) & (ROC_Mom <= -0.2)"
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 1
        },
        "roc_threshold_long": {
            "type": "float",
            "low": -0.5,
            "high": 2.0,
            "step": 0.1
        }
    }
}