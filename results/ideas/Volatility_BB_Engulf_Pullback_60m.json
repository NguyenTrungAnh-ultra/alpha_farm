{
    "name": "Volatility_BB_Engulf_Pullback",
    "timeframe": "60m",
    "family": "volatility",
    "description": "A volatility-based breakout strategy using Bollinger Bands and ATR to filter trades, triggered by an Engulfing pattern. Exits on mean reversion into the middle band.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "open_price",
            "volume"
        ],
        "indicators": [
            {
                "name": "BB_Upper",
                "definition": "self.feat.bbands(close, high, low).upper"
            },
            {
                "name": "BB_Middle",
                "definition": "self.feat.bbands(close, high, low).middle"
            },
            {
                "name": "NATR",
                "definition": "self.feat.natr(high, low, close)"
            }
        ],
        "entry_long": "(close > BB_Upper) & engulfing_pattern == 1",
        "entry_short": "(close < BB_Lower) & engulfing_pattern == -1",
        "exit_long": "(close < BB_Middle)",
        "exit_short": "(close > BB_Middle)"
    },
    "param_space": {
        "bb_period": {
            "type": "int",
            "low": 5,
            "high": 20,
            "step": 1
        },
        "atr_multiplier": {
            "type": "float",
            "low": 0.8,
            "high": 3.0,
            "step": 0.1
        }
    }
}