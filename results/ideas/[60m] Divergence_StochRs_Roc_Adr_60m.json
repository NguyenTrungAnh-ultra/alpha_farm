{
    "name": "[60m] Divergence_StochRs_Roc_Adr",
    "timeframe": "60m",
    "family": "oscillator-divergence",
    "description": "Detects mean-reversion bounces using StochRSI oversold/overbought conditions combined with ROC momentum confirmation, avoiding trend-following logic to prevent overlap with accepted strategies.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low"
        ],
        "indicators": [
            {
                "name": "StochRs",
                "definition": "self.feat.stochrsi(close, timeperiod=14)"
            },
            {
                "name": "ROC",
                "definition": "self.feat.roc(close, timeperiod=5)"
            }
        ],
        "entry_long": "(close >= close_shift(1)) & (stochrs < 30) & (roc > roc_shift(1))",
        "entry_short": "(close <= close_shift(1)) & (stochrs > 70) & (roc < roc_shift(1))",
        "exit_long": "(close <= close_shift(1)) & (stochrs >= 50)",
        "exit_short": "(close >= close_shift(1)) & (stochrs <= 30)"
    },
    "param_space": {
        "timeperiod_roc": {
            "type": "int",
            "low": 2,
            "high": 10,
            "step": 1
        },
        "threshold_stoch_low": {
            "type": "float",
            "low": 5.0,
            "high": 30.0,
            "step": 5.0
        },
        "threshold_stoch_high": {
            "type": "float",
            "low": 70.0,
            "high": 95.0,
            "step": 5.0
        }
    }
}