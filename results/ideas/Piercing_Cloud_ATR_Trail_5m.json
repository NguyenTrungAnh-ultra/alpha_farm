{
    "name": "Piercing_Cloud_ATR_Trail",
    "timeframe": "5m",
    "family": "pattern-based",
    "description": "Uses bullish Piercing pattern for long entries and bearish Dark Cloud Cover for short entries, filtered by trend (EMA) and volatility regime (ATR relative to its SMA). Exits with ATR-based trailing stop or profit target.",
    "formula": {
        "inputs": [
            "open",
            "high",
            "low",
            "close",
            "volume"
        ],
        "indicators": [
            {
                "name": "EMA_trend",
                "definition": "EMA(close, timeperiod=20)"
            },
            {
                "name": "ATR",
                "definition": "ATR(high, low, close, timeperiod=14)"
            },
            {
                "name": "ATR_SMA",
                "definition": "SMA(ATR, timeperiod=20)"
            },
            {
                "name": "Bullish_Piercing",
                "definition": "CDLPIERCING(open, high, low, close)"
            },
            {
                "name": "Bearish_DarkCloud",
                "definition": "CDLDARKCLOUDCOVER(open, high, low, close)"
            },
            {
                "name": "HighestHigh_5",
                "definition": "MAX(high, timeperiod=5)"
            },
            {
                "name": "LowestLow_5",
                "definition": "MIN(low, timeperiod=5)"
            }
        ],
        "entry_long": "(Bullish_Piercing > 0) AND (close < EMA_trend) AND (ATR > vol_filter_mult * ATR_SMA)",
        "entry_short": "(Bearish_DarkCloud < 0) AND (close > EMA_trend) AND (ATR > vol_filter_mult * ATR_SMA)",
        "exit_logic": "Exit long: (close < HighestHigh_5 - trail_mult * ATR) OR (close > EMA_trend + profit_mult * ATR). Exit short: (close > LowestLow_5 + trail_mult * ATR) OR (close < EMA_trend - profit_mult * ATR)."
    },
    "param_space": {
        "ema_period": {
            "type": "int",
            "low": 10,
            "high": 30,
            "step": 2
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "vol_filter_mult": {
            "type": "float",
            "low": 0.3,
            "high": 0.8,
            "step": 0.1
        },
        "trail_mult": {
            "type": "float",
            "low": 1.5,
            "high": 3.0,
            "step": 0.1
        },
        "profit_mult": {
            "type": "float",
            "low": 2.0,
            "high": 4.0,
            "step": 0.2
        },
        "lookback_period": {
            "type": "int",
            "low": 3,
            "high": 10,
            "step": 1
        }
    }
}