{
    "name": "Volatility_Asymmetric_Donchian_Breakout",
    "timeframe": "10m",
    "family": "breakout",
    "description": "A balanced 10-minute intraday strategy engineered to capitalize on structural price expansions in the VN30F1M index while avoiding fakeouts within sideways regimes. The strategy defines its core execution zones using dynamic channel breakouts. To neutralize the systemic risk of zero-volume periods or thin bars, entries are strictly conditioned on an absolute volatility threshold determined by a short-term Standard Deviation relative to its medium-term baseline. Fully vectorized, loop-free exits are processed at the close of the candlestick using an adaptive midprice tracking band.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "Upper_Band",
                "definition": "self.feat.max(high, timeperiod=breakout_period)"
            },
            {
                "name": "Lower_Band",
                "definition": "self.feat.min(low, timeperiod=breakout_period)"
            },
            {
                "name": "Volatility_Fast",
                "definition": "self.feat.stddev(close, timeperiod=10)"
            },
            {
                "name": "Volatility_Slow",
                "definition": "self.feat.sma(self.feat.stddev(close, timeperiod=10), timeperiod=30)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Midprice_Exit",
                "definition": "self.feat.midprice(high, low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(close > Upper_Band) & (Volatility_Fast > Volatility_Slow * expansion_factor)",
        "entry_short": "(close < Lower_Band) & (Volatility_Fast > Volatility_Slow * expansion_factor)",
        "exit_logic": "Exit Long: (close < Midprice_Exit - 0.25 * ATR). Exit Short: (close > Midprice_Exit + 0.25 * ATR)."
    },
    "param_space": {
        "breakout_period": {
            "type": "int",
            "low": 15,
            "high": 35,
            "step": 1
        },
        "expansion_factor": {
            "type": "float",
            "low": 1.1,
            "high": 1.8,
            "step": 0.1
        },
        "exit_period": {
            "type": "int",
            "low": 10,
            "high": 24,
            "step": 2
        }
    }
}