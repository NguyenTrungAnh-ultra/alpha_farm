{
    "name": "Absolute_Price_Oscillator_Volatility_Enforcer",
    "timeframe": "10m",
    "family": "volatility",
    "description": "A 10-minute balanced intraday strategy that relies on macro-volatility cycles to filter out toxic ranging periods common in the VN30F1M index. It flags early institutional structural momentum using the Absolute Price Oscillator (APO), avoiding standard correlated trailing indicator overlaps. Trend transitions are verified by cross-checking the structural direction of the Parabolic SAR. To isolate the strategy from the risk of zero-volume or thin compressed bars, entries require a minimum threshold of Normalized Average True Range (NATR). Vectorized trailing exits use an asset-specific ATR step to capture profits safely before intraday expiration.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "APO",
                "definition": "self.feat.apo(close, fastperiod=fast_apo, slowperiod=slow_apo, matype=1)"
            },
            {
                "name": "SAR",
                "definition": "self.feat.sar(high, low, acceleration=sar_acc, maximum=sar_max)"
            },
            {
                "name": "NATR",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Rolling_Max",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Rolling_Min",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(APO > apo_threshold) & (close > SAR) & (NATR > natr_min)",
        "entry_short": "(APO < -apo_threshold) & (close < SAR) & (NATR > natr_min)",
        "exit_logic": "Exit Long: (close < SAR) or (close < Rolling_Max - (exit_mult * ATR)). Exit Short: (close > SAR) or (close > Rolling_Min + (exit_mult * ATR))."
    },
    "param_space": {
        "fast_apo": {
            "type": "int",
            "low": 10,
            "high": 18,
            "step": 1
        },
        "slow_apo": {
            "type": "int",
            "low": 24,
            "high": 40,
            "step": 2
        },
        "apo_threshold": {
            "type": "float",
            "low": 0.5,
            "high": 3.0,
            "step": 0.25
        },
        "sar_acc": {
            "type": "float",
            "low": 0.01,
            "high": 0.03,
            "step": 0.01
        },
        "sar_max": {
            "type": "float",
            "low": 0.12,
            "high": 0.24,
            "step": 0.02
        },
        "natr_min": {
            "type": "float",
            "low": 0.06,
            "high": 0.18,
            "step": 0.01
        },
        "exit_period": {
            "type": "int",
            "low": 8,
            "high": 16,
            "step": 1
        },
        "exit_mult": {
            "type": "float",
            "low": 1.5,
            "high": 3.5,
            "step": 0.1
        }
    }
}