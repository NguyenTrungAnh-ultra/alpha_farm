{
    "name": "Micro_MACD_Slope_Volatility_Enforcer",
    "timeframe": "1m",
    "family": "multi-indicator",
    "description": "An ultra-fast 1-minute scalping strategy that exploits high-velocity directional shifts in the VN30F1M index while neutralizing short-term noise. It isolates tactical directionality via the linear regression slope of the fast MACD histogram line, completely discarding old lagged indicator definitions. To insulate entries from flat or zero-volume bars, execution is permitted only when true range volatility expands beyond a trailing moving baseline. Out-of-loop vectorized exits track tight rolling channel extremes anchored to historical price thresholds.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "MACD_Hist",
                "definition": "self.feat.macd(close, fastperiod=12, slowperiod=26, signalperiod=9)[2]"
            },
            {
                "name": "Hist_Slope",
                "definition": "self.feat.linearreg_slope(MACD_Hist, timeperiod=slope_period)"
            },
            {
                "name": "TR",
                "definition": "self.feat.trange(high, low, close)"
            },
            {
                "name": "TR_Smooth",
                "definition": "self.feat.sma(TR, timeperiod=20)"
            },
            {
                "name": "Micro_High",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Micro_Low",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(Hist_Slope > slope_trigger) & (TR > TR_Smooth * expansion_factor)",
        "entry_short": "(Hist_Slope < -slope_trigger) & (TR > TR_Smooth * expansion_factor)",
        "exit_logic": "Exit Long: (close < Micro_Low) or (Hist_Slope < 0.0). Exit Short: (close > Micro_High) or (Hist_Slope > 0.0)."
    },
    "param_space": {
        "slope_period": {
            "type": "int",
            "low": 4,
            "high": 10,
            "step": 1
        },
        "slope_trigger": {
            "type": "float",
            "low": 0.02,
            "high": 0.16,
            "step": 0.02
        },
        "expansion_factor": {
            "type": "float",
            "low": 1.05,
            "high": 1.55,
            "step": 0.05
        },
        "exit_period": {
            "type": "int",
            "low": 3,
            "high": 6,
            "step": 1
        }
    }
}