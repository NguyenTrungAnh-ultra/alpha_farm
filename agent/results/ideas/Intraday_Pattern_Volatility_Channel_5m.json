{
    "name": "Intraday_Pattern_Volatility_Channel",
    "timeframe": "5m",
    "family": "pattern-based",
    "description": "A 5-minute standard intraday strategy combining candlestick pattern recognition with structural trend filters. It identifies high-probability directional shifts using the classic Engulfing pattern. To eliminate toxic sideways signals, entries are explicitly conditioned on a structural expansion of the normalized True Range (NATR) and validated by the Commodity Channel Index (CCI) to ensure immediate directional momentum alignment. Exits use a trailing midpoint calculation derived from linear regression paths to avoid strict looping rules.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume",
            "open"
        ],
        "indicators": [
            {
                "name": "Engulfing",
                "definition": "self.feat.cdl_engulfing(open, high, low, close)"
            },
            {
                "name": "CCI",
                "definition": "self.feat.cci(high, low, close, timeperiod=cci_period)"
            },
            {
                "name": "NATR",
                "definition": "self.feat.natr(high, low, close, timeperiod=natr_period)"
            },
            {
                "name": "LR_Center",
                "definition": "self.feat.linearreg(close, timeperiod=lr_period)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            }
        ],
        "entry_long": "(Engulfing > 0) & (CCI > cci_long_bound) & (NATR > natr_threshold)",
        "entry_short": "(Engulfing < 0) & (CCI < cci_short_bound) & (NATR > natr_threshold)",
        "exit_logic": "Exit Long: (close < LR_Center - 0.5 * ATR). Exit Short: (close > LR_Center + 0.5 * ATR)."
    },
    "param_space": {
        "cci_period": {
            "type": "int",
            "low": 10,
            "high": 24,
            "step": 1
        },
        "cci_long_bound": {
            "type": "float",
            "low": -50.0,
            "high": 50.0,
            "step": 5.0
        },
        "cci_short_bound": {
            "type": "float",
            "low": -50.0,
            "high": 50.0,
            "step": 5.0
        },
        "natr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "natr_threshold": {
            "type": "float",
            "low": 0.05,
            "high": 0.25,
            "step": 0.01
        },
        "lr_period": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 1
        }
    }
}