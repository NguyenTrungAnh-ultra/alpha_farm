{
    "name": "Linear_Slope_Plus_DI_Regime_Position",
    "timeframe": "30m",
    "family": "trend-following",
    "description": "A structural 30-minute position intraday strategy designed to track macro institutional trend expansions in the VN30F1M contract while entirely filtering out flat noise segments. It identifies clean directional acceleration using the mathematical slope of a long-period Linear Regression line, bypassing standard moving average lag traps. The structural trend initialization is verified and confirmed via directional index force consensus (Plus_DI vs Minus_DI). To isolate the system from thin or zero-volume horizontal periods, entries require a structural volatility expansion floor where the short standard deviation breaks past an ATR threshold channel. Completely loop-free vectorized trailing exits use rolling price extremes.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "Slope",
                "definition": "self.feat.linearreg_slope(close, timeperiod=slope_period)"
            },
            {
                "name": "Plus_DI",
                "definition": "self.feat.plus_di(high, low, close, timeperiod=di_period)"
            },
            {
                "name": "Minus_DI",
                "definition": "self.feat.minus_di(high, low, close, timeperiod=di_period)"
            },
            {
                "name": "Volatility_Fast",
                "definition": "self.feat.stddev(close, timeperiod=10)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=20)"
            },
            {
                "name": "Rolling_Max",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Rolling_Min",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(Slope > slope_threshold) & (Plus_DI > Minus_DI) & (Volatility_Fast > ATR * expansion_factor)",
        "entry_short": "(Slope < -slope_threshold) & (Minus_DI > Plus_DI) & (Volatility_Fast > ATR * expansion_factor)",
        "exit_logic": "Exit Long: (Slope < 0.0) or (close < Rolling_Max - (exit_mult * ATR)). Exit Short: (Slope > 0.0) or (close > Rolling_Min + (exit_mult * ATR))."
    },
    "param_space": {
        "slope_period": {
            "type": "int",
            "low": 25,
            "high": 55,
            "step": 1
        },
        "slope_threshold": {
            "type": "float",
            "low": 0.05,
            "high": 0.25,
            "step": 0.02
        },
        "di_period": {
            "type": "int",
            "low": 14,
            "high": 28,
            "step": 1
        },
        "expansion_factor": {
            "type": "float",
            "low": 0.6,
            "high": 1.3,
            "step": 0.05
        },
        "exit_period": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 1
        },
        "exit_mult": {
            "type": "float",
            "low": 2.5,
            "high": 4.5,
            "step": 0.1
        }
    }
}