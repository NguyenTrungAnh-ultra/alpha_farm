{
    "name": "Keltner_Adaptive_Trend_Breakout",
    "timeframe": "5m",
    "family": "breakout",
    "description": "An intraday breakout strategy built on the 5-minute timeframe. It identifies market regimes using the ADX indicator to filter out choppy sideways price action. Entry signals are generated when the price breaks out of an adaptive Keltner Channel constructed via an EMA and ATR. Exits are dynamically managed using a trailing Chandelier Exit logic based on historical rolling extremes and ATR to maintain vectorization compatibility.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "ADX",
                "definition": "self.feat.adx(high, low, close, timeperiod=adx_period)"
            },
            {
                "name": "EMA_mid",
                "definition": "self.feat.ema(close, timeperiod=ema_period)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=atr_period)"
            },
            {
                "name": "Upper_Band",
                "definition": "EMA_mid + (kc_mult * ATR)"
            },
            {
                "name": "Lower_Band",
                "definition": "EMA_mid - (kc_mult * ATR)"
            },
            {
                "name": "Highest_High",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Lowest_Low",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            },
            {
                "name": "Long_Trailing_Stop",
                "definition": "Highest_High - (exit_mult * ATR)"
            },
            {
                "name": "Short_Trailing_Stop",
                "definition": "Lowest_Low + (exit_mult * ATR)"
            }
        ],
        "entry_long": "(ADX > adx_threshold) & (close > Upper_Band)",
        "entry_short": "(ADX > adx_threshold) & (close < Lower_Band)",
        "exit_logic": "Exit Long: (close < Long_Trailing_Stop) or (close < EMA_mid). Exit Short: (close > Short_Trailing_Stop) or (close > EMA_mid)."
    },
    "param_space": {
        "adx_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "adx_threshold": {
            "type": "float",
            "low": 15.0,
            "high": 25.0,
            "step": 0.5
        },
        "ema_period": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 1
        },
        "atr_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "kc_mult": {
            "type": "float",
            "low": 1.0,
            "high": 2.5,
            "step": 0.1
        },
        "exit_period": {
            "type": "int",
            "low": 5,
            "high": 15,
            "step": 1
        },
        "exit_mult": {
            "type": "float",
            "low": 2.0,
            "high": 4.0,
            "step": 0.1
        }
    }
}