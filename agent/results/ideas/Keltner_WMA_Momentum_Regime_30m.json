{
    "name": "Keltner_WMA_Momentum_Regime",
    "timeframe": "30m",
    "family": "channel",
    "description": "A structural 30-minute position intraday strategy designed to capture high-probability macro trend legs in the VN30F1M contract. It tracks the institutional value baseline using a medium-period Weighted Moving Average (WMA). Breakout channels are established dynamically around this WMA baseline using the Average True Range (ATR). To prevent the algorithm from being chopped up within the market's common narrow sideways phases and to avoid division traps on flat or zero-volume bars, entries require a momentum velocity confirmation from a medium-period Rate of Change (ROC). Vectorized loop-free exits are executed using trailing price extrema and an ATR buffer.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "WMA_Baseline",
                "definition": "self.feat.wma(close, timeperiod=wma_period)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Upper_Band",
                "definition": "WMA_Baseline + (channel_mult * ATR)"
            },
            {
                "name": "Lower_Band",
                "definition": "WMA_Baseline - (channel_mult * ATR)"
            },
            {
                "name": "ROC",
                "definition": "self.feat.roc(close, timeperiod=roc_period)"
            },
            {
                "name": "Rolling_Max",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Rolling_Min",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(close > Upper_Band) & (ROC > roc_threshold)",
        "entry_short": "(close < Lower_Band) & (ROC < -roc_threshold)",
        "exit_logic": "Exit Long: (close < WMA_Baseline) or (close < Rolling_Max - (exit_mult * ATR)). Exit Short: (close > WMA_Baseline) or (close > Rolling_Min + (exit_mult * ATR))."
    },
    "param_space": {
        "wma_period": {
            "type": "int",
            "low": 20,
            "high": 45,
            "step": 1
        },
        "channel_mult": {
            "type": "float",
            "low": 1.2,
            "high": 2.8,
            "step": 0.1
        },
        "roc_period": {
            "type": "int",
            "low": 10,
            "high": 22,
            "step": 1
        },
        "roc_threshold": {
            "type": "float",
            "low": 0.2,
            "high": 1.2,
            "step": 0.05
        },
        "exit_period": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 1
        },
        "exit_mult": {
            "type": "float",
            "low": 2.5,
            "high": 4.5,
            "step": 0.1
        }
    }
}