{
    "name": "Triple_Exponential_CCI_Volatility_Regime",
    "timeframe": "10m",
    "family": "multi-indicator",
    "description": "A balanced 10-minute intraday strategy tracking momentum continuations on the VN30F1M contract. It defines the core market bias using a medium-period Triple Exponential Moving Average (TEMA). Velocity transformations are tracked when a smoothed Commodity Channel Index (CCI) crosses beyond its typical operational boundaries. To safeguard execution capital from toxic sideways ranges and completely avoid division traps on thin or zero-volume bars, entries require structural filter verification from a Normalized ATR (NATR) threshold curve. Vectorized, loop-free exits are anchored around trailing price extremes.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "TEMA",
                "definition": "self.feat.tema(close, timeperiod=tema_period)"
            },
            {
                "name": "CCI_Fast",
                "definition": "self.feat.cci(high, low, close, timeperiod=cci_period)"
            },
            {
                "name": "CCI_Smooth",
                "definition": "self.feat.wma(CCI_Fast, timeperiod=5)"
            },
            {
                "name": "NATR",
                "definition": "self.feat.natr(high, low, close, timeperiod=14)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Rolling_Max",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Rolling_Min",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(close > TEMA) & (CCI_Smooth > cci_bound) & (NATR > natr_min)",
        "entry_short": "(close < TEMA) & (CCI_Smooth < -cci_bound) & (NATR > natr_min)",
        "exit_logic": "Exit Long: (close < TEMA) or (close < Rolling_Max - (exit_mult * ATR)). Exit Short: (close > TEMA) or (close > Rolling_Min + (exit_mult * ATR))."
    },
    "param_space": {
        "tema_period": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 2
        },
        "cci_period": {
            "type": "int",
            "low": 12,
            "high": 24,
            "step": 1
        },
        "cci_bound": {
            "type": "float",
            "low": 75.0,
            "high": 115.0,
            "step": 5.0
        },
        "natr_min": {
            "type": "float",
            "low": 0.06,
            "high": 0.16,
            "step": 0.01
        },
        "exit_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "exit_mult": {
            "type": "float",
            "low": 2.0,
            "high": 3.8,
            "step": 0.1
        }
    }
}