{
    "name": "Session_Chande_Volatility_Breakout",
    "timeframe": "30m",
    "family": "session-based",
    "description": "A structural position-intraday strategy designed for the 30-minute timeframe of the VN30F1M contract. It capitalizes on institutional momentum following early-session range stabilization. The strategy tracks structural breakouts using a medium-term rolling high/low channel. To avoid classic false breakouts typical in the Vietnamese derivatives market, entry signals must be validated by a directional momentum trend surge via the Chande Momentum Oscillator (CMO) and a high-regime volatility confirmation using the True Range. Exits are dynamically calculated using an adaptive technical baseline anchored on the rolling midpoint.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "Session_High",
                "definition": "self.feat.max(high, timeperiod=range_period)"
            },
            {
                "name": "Session_Low",
                "definition": "self.feat.min(low, timeperiod=range_period)"
            },
            {
                "name": "CMO",
                "definition": "self.feat.cmo(close, timeperiod=cmo_period)"
            },
            {
                "name": "TR",
                "definition": "self.feat.trange(high, low, close)"
            },
            {
                "name": "ATR_Filter",
                "definition": "self.feat.atr(high, low, close, timeperiod=30)"
            },
            {
                "name": "Midpoint",
                "definition": "self.feat.midprice(high, low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(close > Session_High) & (CMO > cmo_threshold) & (TR > ATR_Filter)",
        "entry_short": "(close < Session_Low) & (CMO < -cmo_threshold) & (TR > ATR_Filter)",
        "exit_logic": "Exit Long: (close < Midpoint). Exit Short: (close > Midpoint)."
    },
    "param_space": {
        "range_period": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 2
        },
        "cmo_period": {
            "type": "int",
            "low": 14,
            "high": 28,
            "step": 1
        },
        "cmo_threshold": {
            "type": "float",
            "low": 10.0,
            "high": 35.0,
            "step": 5.0
        },
        "exit_period": {
            "type": "int",
            "low": 15,
            "high": 35,
            "step": 1
        }
    }
}