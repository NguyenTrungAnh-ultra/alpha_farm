{
    "name": "Midprice_Regression_Oscillator_Trend",
    "timeframe": "5m",
    "family": "channel",
    "description": "A 5-minute standard intraday strategy tracking mathematical price channels via linear regression paths. It defines an institutional trend anchor using the rolling Midprice moving average. Entry boundaries are derived from standard deviations above and below this anchor to capture technical breakouts out of tight squeeze regimes. To bypass choppy sideways noise and avoid division traps on flat or zero-volume bars, entries require confirmation from a sustained trend index (ADXR). Array-based vectorized exits track a dynamic rolling midpoint combined with an ATR offset.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "Mid_Anchor",
                "definition": "self.feat.midprice(high, low, timeperiod=anchor_period)"
            },
            {
                "name": "StdDev",
                "definition": "self.feat.stddev(close, timeperiod=anchor_period)"
            },
            {
                "name": "Upper_Channel",
                "definition": "Mid_Anchor + (channel_mult * StdDev)"
            },
            {
                "name": "Lower_Channel",
                "definition": "Mid_Anchor - (channel_mult * StdDev)"
            },
            {
                "name": "ADXR",
                "definition": "self.feat.adxr(high, low, close, timeperiod=14)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Rolling_Max",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Rolling_Min",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(close > Upper_Channel) & (ADXR > adxr_min)",
        "entry_short": "(close < Lower_Channel) & (ADXR > adxr_min)",
        "exit_logic": "Exit Long: (close < Mid_Anchor) or (close < Rolling_Max - (exit_mult * ATR)). Exit Short: (close > Mid_Anchor) or (close > Rolling_Min + (exit_mult * ATR))."
    },
    "param_space": {
        "anchor_period": {
            "type": "int",
            "low": 15,
            "high": 35,
            "step": 1
        },
        "channel_mult": {
            "type": "float",
            "low": 1.2,
            "high": 2.6,
            "step": 0.1
        },
        "adxr_min": {
            "type": "float",
            "low": 15.0,
            "high": 25.0,
            "step": 0.5
        },
        "exit_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "exit_mult": {
            "type": "float",
            "low": 1.5,
            "high": 3.5,
            "step": 0.1
        }
    }
}