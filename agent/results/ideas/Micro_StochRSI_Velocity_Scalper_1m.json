{
    "name": "Micro_StochRSI_Velocity_Scalper",
    "timeframe": "1m",
    "family": "momentum",
    "description": "An ultra-fast 1-minute scalping strategy engineered to capture explosive directional impulses in the VN30F1M contract while filtering out high-frequency noise. It uses StochRSI over a hyper-short lookback window to pinpoint rapid momentum velocity changes. To counter the pitfalls of choppy sideways regimes and the occurrence of zero-volume bars, entries are strictly conditioned on an absolute directional trend index (DX) threshold and a baseline standard deviation floor. Vectorized loop-free exits are triggered when the fast Stochastic %K line crosses its corresponding signal line or breaches tight rolling channels.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "Stoch_K",
                "definition": "self.feat.stochrsi(close, timeperiod=stoch_period, fastk_period=5, fastd_period=3, fastd_matype=0)[0]"
            },
            {
                "name": "Stoch_D",
                "definition": "self.feat.stochrsi(close, timeperiod=stoch_period, fastk_period=5, fastd_period=3, fastd_matype=0)[1]"
            },
            {
                "name": "DX",
                "definition": "self.feat.dx(high, low, close, timeperiod=dx_period)"
            },
            {
                "name": "Noise_Filter",
                "definition": "self.feat.stddev(close, timeperiod=10)"
            },
            {
                "name": "Micro_High",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Micro_Low",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(Stoch_K > Stoch_D) & (Stoch_K < 30.0) & (DX > dx_threshold) & (Noise_Filter > noise_floor)",
        "entry_short": "(Stoch_K < Stoch_D) & (Stoch_K > 70.0) & (DX > dx_threshold) & (Noise_Filter > noise_floor)",
        "exit_logic": "Exit Long: (Stoch_K < Stoch_D) or (close < Micro_Low). Exit Short: (Stoch_K > Stoch_D) or (close > Micro_High)."
    },
    "param_space": {
        "stoch_period": {
            "type": "int",
            "low": 8,
            "high": 15,
            "step": 1
        },
        "dx_period": {
            "type": "int",
            "low": 10,
            "high": 15,
            "step": 1
        },
        "dx_threshold": {
            "type": "float",
            "low": 20.0,
            "high": 40.0,
            "step": 2.5
        },
        "noise_floor": {
            "type": "float",
            "low": 0.4,
            "high": 1.2,
            "step": 0.1
        },
        "exit_period": {
            "type": "int",
            "low": 3,
            "high": 5,
            "step": 1
        }
    }
}