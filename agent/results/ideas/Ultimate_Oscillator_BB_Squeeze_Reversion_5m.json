{
    "name": "Ultimate_Oscillator_BB_Squeeze_Reversion",
    "timeframe": "5m",
    "family": "mean-reversion",
    "description": "A 5-minute standard intraday mean-reversion strategy designed to capture structural turning points out of quiet market regimes. It uses a Bollinger Bands squeeze condition based on standard deviation bandwidth to confirm that the market is tightly coiled. Reversal signals are generated via multi-timeframe buying pressure tracking via the Ultimate Oscillator (ULTOSC) reaching standard statistical exhaustion boundaries. Vectorized exits are handled via an adaptive trailing channel anchored to the rolling midprice and the Average True Range (ATR).",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "BB_Upper",
                "definition": "self.feat.bbands(close, timeperiod=bb_period, nbdevup=bb_mult, nbdevdn=bb_mult)[0]"
            },
            {
                "name": "BB_Lower",
                "definition": "self.feat.bbands(close, timeperiod=bb_period, nbdevup=bb_mult, nbdevdn=bb_mult)[2]"
            },
            {
                "name": "BB_Bandwidth",
                "definition": "(BB_Upper - BB_Lower) / (self.feat.midpoint(close, timeperiod=bb_period) + 1e-8)"
            },
            {
                "name": "ULTOSC",
                "definition": "self.feat.ultosc(high, low, close, timeperiod1=7, timeperiod2=14, timeperiod3=28)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Midprice_Exit",
                "definition": "self.feat.midprice(high, low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(BB_Bandwidth < squeeze_threshold) & (ULTOSC < oversold_bound) & (close < BB_Lower)",
        "entry_short": "(BB_Bandwidth < squeeze_threshold) & (ULTOSC > overbought_bound) & (close > BB_Upper)",
        "exit_logic": "Exit Long: (close > Midprice_Exit) or (close < BB_Lower - 1.0 * ATR). Exit Short: (close < Midprice_Exit) or (close > BB_Upper + 1.0 * ATR)."
    },
    "param_space": {
        "bb_period": {
            "type": "int",
            "low": 15,
            "high": 25,
            "step": 1
        },
        "bb_mult": {
            "type": "float",
            "low": 1.8,
            "high": 2.5,
            "step": 0.1
        },
        "squeeze_threshold": {
            "type": "float",
            "low": 0.005,
            "high": 0.025,
            "step": 0.002
        },
        "oversold_bound": {
            "type": "float",
            "low": 25.0,
            "high": 35.0,
            "step": 1.0
        },
        "overbought_bound": {
            "type": "float",
            "low": 65.0,
            "high": 75.0,
            "step": 1.0
        },
        "exit_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 2
        }
    }
}