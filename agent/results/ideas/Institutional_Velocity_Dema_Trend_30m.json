{
    "name": "Institutional_Velocity_Dema_Trend",
    "timeframe": "30m",
    "family": "trend-following",
    "description": "A robust 30-minute position-intraday strategy designed to track long-term institutional trend shifts in the VN30F1M contract. It determines structural value using a long lookback Double Exponential Moving Average (DEMA) to cancel out daytime noise. Real-time trend acceleration is validated using the Momentum (MOM) indicator to prevent entries during late-stage exhaustion or fading trends. Flat-regime protection is explicitly handled by an ADXR filter, which measures changes in trend strength to bypass choppy sideways phases. Exits are structured vectorially via a flexible midprice channel anchor matched with an ATR band.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "DEMA",
                "definition": "self.feat.dema(close, timeperiod=dema_period)"
            },
            {
                "name": "MOM",
                "definition": "self.feat.mom(close, timeperiod=mom_period)"
            },
            {
                "name": "ADXR",
                "definition": "self.feat.adxr(high, low, close, timeperiod=adxr_period)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Midprice_Exit",
                "definition": "self.feat.midprice(high, low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(close > DEMA) & (MOM > mom_threshold) & (ADXR > adxr_min)",
        "entry_short": "(close < DEMA) & (MOM < -mom_threshold) & (ADXR > adxr_min)",
        "exit_logic": "Exit Long: (close < Midprice_Exit - 0.5 * ATR) or (MOM < 0.0). Exit Short: (close > Midprice_Exit + 0.5 * ATR) or (MOM > 0.0)."
    },
    "param_space": {
        "dema_period": {
            "type": "int",
            "low": 30,
            "high": 60,
            "step": 2
        },
        "mom_period": {
            "type": "int",
            "low": 14,
            "high": 28,
            "step": 1
        },
        "mom_threshold": {
            "type": "float",
            "low": 1.0,
            "high": 5.0,
            "step": 0.5
        },
        "adxr_period": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 2
        },
        "adxr_min": {
            "type": "float",
            "low": 15.0,
            "high": 25.0,
            "step": 0.5
        },
        "exit_period": {
            "type": "int",
            "low": 15,
            "high": 30,
            "step": 1
        }
    }
}