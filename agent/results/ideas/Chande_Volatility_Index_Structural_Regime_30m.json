{
    "name": "Chande_Volatility_Index_Structural_Regime",
    "timeframe": "30m",
    "family": "session-based",
    "description": "A structural 30-minute position intraday strategy built to capture macro-institutional trend breakouts in the VN30F1M contract. It tracks the core directional index regime via Chande Momentum Oscillator (CMO) trends filtered through a slow Triple Exponential Moving Average (TEMA). To prevent getting chopped up in narrow sideways markets or experiencing division errors during flat bars (Volume = 0), entries require an absolute volatility expansion trigger. This trigger verifies that standard deviation has expanded past its trailing median anchor. Vectorized trailing exits use an adaptive midprice envelope with an ATR buffer to manage the trade through broad multi-hour swings.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "TEMA_Basis",
                "definition": "self.feat.tema(close, timeperiod=tema_period)"
            },
            {
                "name": "CMO",
                "definition": "self.feat.cmo(close, timeperiod=cmo_period)"
            },
            {
                "name": "Volatility_Fast",
                "definition": "self.feat.stddev(close, timeperiod=10)"
            },
            {
                "name": "Volatility_Baseline",
                "definition": "self.feat.midpoint(Volatility_Fast, timeperiod=30)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Midprice_Exit",
                "definition": "self.feat.midprice(high, low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(close > TEMA_Basis) & (CMO > cmo_threshold) & (Volatility_Fast > Volatility_Baseline * expansion_mult)",
        "entry_short": "(close < TEMA_Basis) & (CMO < -cmo_threshold) & (Volatility_Fast > Volatility_Baseline * expansion_mult)",
        "exit_logic": "Exit Long: (close < Midprice_Exit - 0.5 * ATR) or (CMO < 0.0). Exit Short: (close > Midprice_Exit + 0.5 * ATR) or (CMO > 0.0)."
    },
    "param_space": {
        "tema_period": {
            "type": "int",
            "low": 30,
            "high": 60,
            "step": 2
        },
        "cmo_period": {
            "type": "int",
            "low": 14,
            "high": 28,
            "step": 1
        },
        "cmo_threshold": {
            "type": "float",
            "low": 10.0,
            "high": 30.0,
            "step": 2.5
        },
        "expansion_mult": {
            "type": "float",
            "low": 1.0,
            "high": 1.6,
            "step": 0.05
        },
        "exit_period": {
            "type": "int",
            "low": 16,
            "high": 32,
            "step": 2
        }
    }
}