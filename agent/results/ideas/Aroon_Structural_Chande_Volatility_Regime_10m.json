{
    "name": "Aroon_Structural_Chande_Volatility_Regime",
    "timeframe": "10m",
    "family": "oscillator-divergence",
    "description": "A balanced 10-minute timeframe strategy designed to exploit major momentum turning points in the VN30F1M contract while isolating the execution from sideways chop. It monitors multi-day trend cycles using an Aroon Oscillator threshold. Pullback inflection consensus is confirmed using the Chande Momentum Oscillator (CMO) breaking out of equilibrium boundaries. To insulate the logic from deceptive low-liquidity spikes or thin bars (Volume = 0 scenarios), entries require an active structural volatility filter where short standard deviation stretches past a trailing baseline. Vectorized, loop-free exits are tracked using an adaptive midprice envelope with an ATR offset.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "Aroon_Osc",
                "definition": "self.feat.aroonosc(high, low, timeperiod=aroon_period)"
            },
            {
                "name": "CMO",
                "definition": "self.feat.cmo(close, timeperiod=cmo_period)"
            },
            {
                "name": "Volatility_Fast",
                "definition": "self.feat.stddev(close, timeperiod=10)"
            },
            {
                "name": "Volatility_Base",
                "definition": "self.feat.sma(Volatility_Fast, timeperiod=30)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Midprice_Exit",
                "definition": "self.feat.midprice(high, low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(Aroon_Osc > aroon_min) & (CMO > cmo_trigger) & (Volatility_Fast > Volatility_Base * expansion_mult)",
        "entry_short": "(Aroon_Osc < -aroon_min) & (CMO < -cmo_trigger) & (Volatility_Fast > Volatility_Base * expansion_mult)",
        "exit_logic": "Exit Long: (close < Midprice_Exit - 0.5 * ATR) or (CMO < 0.0). Exit Short: (close > Midprice_Exit + 0.5 * ATR) or (CMO > 0.0)."
    },
    "param_space": {
        "aroon_period": {
            "type": "int",
            "low": 20,
            "high": 40,
            "step": 2
        },
        "aroon_min": {
            "type": "float",
            "low": 20.0,
            "high": 60.0,
            "step": 5.0
        },
        "cmo_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "cmo_trigger": {
            "type": "float",
            "low": 10.0,
            "high": 35.0,
            "step": 5.0
        },
        "expansion_mult": {
            "type": "float",
            "low": 1.05,
            "high": 1.65,
            "step": 0.05
        },
        "exit_period": {
            "type": "int",
            "low": 12,
            "high": 28,
            "step": 2
        }
    }
}