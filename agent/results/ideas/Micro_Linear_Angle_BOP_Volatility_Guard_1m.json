{
    "name": "Micro_Linear_Angle_BOP_Volatility_Guard",
    "timeframe": "1m",
    "family": "pattern-based",
    "description": "An ultra-fast 1-minute scalping strategy engineered to capitalize on explosive directional momentum spikes in the VN30F1M contract. It tracks instantaneous trend trajectory using the Linear Regression Angle of the close price over a micro lookback period. To filter out deceptive fakeouts inherent to the noisy 1-minute timeframe and prevent division-by-zero errors on flat bars, true structural capital accumulation is verified via the Balance of Power (BOP) smoothed with a short WMA. Entries are explicitly blocked during quiet sideways regimes unless immediate absolute volatility expands past a moving historical deviation floor. Vectorized loop-free exits track micro-channel price boundaries.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume",
            "open"
        ],
        "indicators": [
            {
                "name": "LR_Angle",
                "definition": "self.feat.linearreg_angle(close, timeperiod=angle_period)"
            },
            {
                "name": "BOP",
                "definition": "self.feat.bop(open, high, low, close)"
            },
            {
                "name": "BOP_Smooth",
                "definition": "self.feat.wma(BOP, timeperiod=4)"
            },
            {
                "name": "Volatility_Fast",
                "definition": "self.feat.stddev(close, timeperiod=8)"
            },
            {
                "name": "Volatility_Base",
                "definition": "self.feat.sma(Volatility_Fast, timeperiod=24)"
            },
            {
                "name": "Micro_High",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Micro_Low",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(LR_Angle > angle_trigger) & (BOP_Smooth > bop_min) & (Volatility_Fast > Volatility_Base * expansion_ratio)",
        "entry_short": "(LR_Angle < -angle_trigger) & (BOP_Smooth < -bop_min) & (Volatility_Fast > Volatility_Base * expansion_ratio)",
        "exit_logic": "Exit Long: (close < Micro_Low) or (LR_Angle < 0.0). Exit Short: (close > Micro_High) or (LR_Angle > 0.0)."
    },
    "param_space": {
        "angle_period": {
            "type": "int",
            "low": 5,
            "high": 12,
            "step": 1
        },
        "angle_trigger": {
            "type": "float",
            "low": 15.0,
            "high": 45.0,
            "step": 2.5
        },
        "bop_min": {
            "type": "float",
            "low": 0.05,
            "high": 0.25,
            "step": 0.05
        },
        "expansion_ratio": {
            "type": "float",
            "low": 1.05,
            "high": 1.55,
            "step": 0.05
        },
        "exit_period": {
            "type": "int",
            "low": 3,
            "high": 5,
            "step": 1
        }
    }
}