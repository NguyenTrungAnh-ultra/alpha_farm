{
    "name": "Chande_Momentum_WMA_Channel_System",
    "timeframe": "10m",
    "family": "channel",
    "description": "A balanced 10-minute intraday channel strategy optimized for the VN30F1M contract. It tracks localized structural momentum shifts using the Chande Momentum Oscillator (CMO). Trend transitions are anchored to a medium-term Weighted Moving Average (WMA) channel center. To isolate valid trade entries from low-liquidity phases or flat-bar regimes (Volume = 0 scenarios), execution is strictly contingent upon a dynamic True Range expansion floor relative to its moving ATR baseline. Vectorized trailing channel exits protect open positions prior to the market session close.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "WMA_Center",
                "definition": "self.feat.wma(close, timeperiod=wma_period)"
            },
            {
                "name": "CMO",
                "definition": "self.feat.cmo(close, timeperiod=cmo_period)"
            },
            {
                "name": "TR",
                "definition": "self.feat.trange(high, low, close)"
            },
            {
                "name": "ATR_Baseline",
                "definition": "self.feat.atr(high, low, close, timeperiod=30)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Rolling_Max",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Rolling_Min",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(close > WMA_Center) & (CMO > cmo_trigger) & (TR > ATR_Baseline * vol_floor)",
        "entry_short": "(close < WMA_Center) & (CMO < -cmo_trigger) & (TR > ATR_Baseline * vol_floor)",
        "exit_logic": "Exit Long: (close < WMA_Center) or (close < Rolling_Max - (exit_mult * ATR)). Exit Short: (close > WMA_Center) or (close > Rolling_Min + (exit_mult * ATR))."
    },
    "param_space": {
        "wma_period": {
            "type": "int",
            "low": 15,
            "high": 35,
            "step": 1
        },
        "cmo_period": {
            "type": "int",
            "low": 10,
            "high": 22,
            "step": 1
        },
        "cmo_trigger": {
            "type": "float",
            "low": 10.0,
            "high": 30.0,
            "step": 2.5
        },
        "vol_floor": {
            "type": "float",
            "low": 0.7,
            "high": 1.4,
            "step": 0.05
        },
        "exit_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "exit_mult": {
            "type": "float",
            "low": 1.5,
            "high": 3.5,
            "step": 0.1
        }
    }
}