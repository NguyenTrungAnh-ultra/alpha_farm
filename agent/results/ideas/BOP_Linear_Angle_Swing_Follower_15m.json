{
    "name": "BOP_Linear_Angle_Swing_Follower",
    "timeframe": "15m",
    "family": "momentum",
    "description": "A high-quality 15-minute swing intraday strategy focusing on structural consensus breakouts. It utilizes the Balance of Power (BOP) indicator to assess pure underlying buying/selling pressure independent of volume anomalies, avoiding division-by-zero risks on flat bars. Trend directionality and trajectory sharpness are validated via the Linear Regression Angle to circumvent choppy trend regimes. Vectorized, loop-free exits are executed using the True Range and historical price extremes to track volatility decay at the close of the candlestick.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume",
            "open"
        ],
        "indicators": [
            {
                "name": "BOP",
                "definition": "self.feat.bop(open, high, low, close)"
            },
            {
                "name": "BOP_Smooth",
                "definition": "self.feat.sma(BOP, timeperiod=smooth_period)"
            },
            {
                "name": "LR_Angle",
                "definition": "self.feat.linearreg_angle(close, timeperiod=angle_period)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Rolling_Max",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Rolling_Min",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(BOP_Smooth > bop_threshold) & (LR_Angle > angle_threshold)",
        "entry_short": "(BOP_Smooth < -bop_threshold) & (LR_Angle < -angle_threshold)",
        "exit_logic": "Exit Long: (close < Rolling_Max - (exit_mult * ATR)) or (LR_Angle < 0.0). Exit Short: (close > Rolling_Min + (exit_mult * ATR)) or (LR_Angle > 0.0)."
    },
    "param_space": {
        "smooth_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "angle_period": {
            "type": "int",
            "low": 14,
            "high": 30,
            "step": 2
        },
        "bop_threshold": {
            "type": "float",
            "low": 0.05,
            "high": 0.25,
            "step": 0.05
        },
        "angle_threshold": {
            "type": "float",
            "low": 10.0,
            "high": 35.0,
            "step": 2.5
        },
        "exit_period": {
            "type": "int",
            "low": 8,
            "high": 18,
            "step": 1
        },
        "exit_mult": {
            "type": "float",
            "low": 1.5,
            "high": 3.5,
            "step": 0.1
        }
    }
}