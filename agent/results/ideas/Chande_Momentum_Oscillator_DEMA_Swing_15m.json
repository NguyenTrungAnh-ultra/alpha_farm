{
    "name": "Chande_Momentum_Oscillator_DEMA_Swing",
    "timeframe": "15m",
    "family": "oscillator-divergence",
    "description": "A high-quality 15-minute swing intraday strategy designed to trade strong directional momentum waves in the VN30F1M contract while filtering out flat noise regimes. It captures early price velocity changes using a fast Double Exponential Moving Average (DEMA) slope line. Signals are validated by an underlying momentum surge via the Chande Momentum Oscillator (CMO) breaking out of standard equilibrium boundaries. To ensure protection against fakeouts during compressed sideways periods, entries require a structural volatility filter based on True Range expansion relative to its historical baseline. Fully vectorized exits utilize a combination of dynamic midprice tracking and trailing ATR boundaries.",
    "formula": {
        "inputs": [
            "close",
            "high",
            "low",
            "volume"
        ],
        "indicators": [
            {
                "name": "DEMA_Fast",
                "definition": "self.feat.dema(close, timeperiod=dema_period)"
            },
            {
                "name": "DEMA_Slope",
                "definition": "self.feat.linearreg_slope(DEMA_Fast, timeperiod=5)"
            },
            {
                "name": "CMO",
                "definition": "self.feat.cmo(close, timeperiod=cmo_period)"
            },
            {
                "name": "TR",
                "definition": "self.feat.trange(high, low, close)"
            },
            {
                "name": "ATR_Filter",
                "definition": "self.feat.atr(high, low, close, timeperiod=30)"
            },
            {
                "name": "ATR",
                "definition": "self.feat.atr(high, low, close, timeperiod=14)"
            },
            {
                "name": "Rolling_Max",
                "definition": "self.feat.max(high, timeperiod=exit_period)"
            },
            {
                "name": "Rolling_Min",
                "definition": "self.feat.min(low, timeperiod=exit_period)"
            }
        ],
        "entry_long": "(DEMA_Slope > slope_threshold) & (CMO > cmo_trigger) & (TR > ATR_Filter * vol_factor)",
        "entry_short": "(DEMA_Slope < -slope_threshold) & (CMO < -cmo_trigger) & (TR > ATR_Filter * vol_factor)",
        "exit_logic": "Exit Long: (close < Rolling_Max - (exit_mult * ATR)) or (CMO < 0.0). Exit Short: (close > Rolling_Min + (exit_mult * ATR)) or (CMO > 0.0)."
    },
    "param_space": {
        "dema_period": {
            "type": "int",
            "low": 10,
            "high": 24,
            "step": 1
        },
        "slope_threshold": {
            "type": "float",
            "low": 0.05,
            "high": 0.35,
            "step": 0.05
        },
        "cmo_period": {
            "type": "int",
            "low": 10,
            "high": 20,
            "step": 1
        },
        "cmo_trigger": {
            "type": "float",
            "low": 10.0,
            "high": 35.0,
            "step": 5.0
        },
        "vol_factor": {
            "type": "float",
            "low": 0.8,
            "high": 1.5,
            "step": 0.1
        },
        "exit_period": {
            "type": "int",
            "low": 10,
            "high": 22,
            "step": 1
        },
        "exit_mult": {
            "type": "float",
            "low": 2.0,
            "high": 4.0,
            "step": 0.1
        }
    }
}